{
  "name": "chill-dogs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node src/scripts/generate-og-images.mjs",
    "build": "astro build && node scripts/indexnow-submit.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:smoke": "vitest run src/__tests__/site-smoke.test.ts",
    "test:coverage": "vitest run --coverage",
    "prepare": "simple-git-hooks",
    "indexnow:submit": "node scripts/indexnow-submit.mjs"
  },
  "simple-git-hooks": {
    "pre-commit": "npm test && npm run test:smoke"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "@fontsource-variable/nunito": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@vercel/speed-insights": "^1.3.1",
    "astro": "^5.18.0",
    "astro-robots-txt": "^1.0.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.7.0",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "vitest": "^4.0.18"
  }
}
