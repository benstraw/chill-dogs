---
import PostLayout from '@layouts/PostLayout.astro';
import ConverterLayout from '@layouts/ConverterLayout.astro';
import StructuredData from '@components/StructuredData.astro';
import { render } from 'astro:content';
import { getPostsForCategory, getSlugFromId } from '@utils/collection-helpers';

export async function getStaticPaths() {
  const posts = await getPostsForCategory('gift-guides');
  return posts.map((post) => ({
    params: { slug: getSlugFromId(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, heroImage, ogImage, category, pageType, products } = post.data;
---

<StructuredData type="article" title={title} description={description} date={date} />

{pageType === 'converter' ? (
  <ConverterLayout
    title={title}
    description={description}
    date={date}
    heroImage={heroImage}
    ogImage={ogImage}
    category={category}
    products={products}
  >
    <Content />
  </ConverterLayout>
) : (
  <PostLayout
    title={title}
    description={description}
    date={date}
    heroImage={heroImage}
    ogImage={ogImage}
    category={category}
  >
    <Content />
  </PostLayout>
)}
