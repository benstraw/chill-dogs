---
import { ROUTES } from '@data/routes';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/modules/Hero.astro';
import Toc from '@components/modules/Toc.astro';
import FAQ from '@components/modules/FAQ.astro';
import Disclosure from '@components/modules/Disclosure.astro';
import InternalLinkStrip from '@components/modules/InternalLinkStrip.astro';
import JsonLd from '@components/JsonLd.astro';
import AffiliateLink from '@components/AffiliateLink.astro';
import { trackerProducts, getTrackersByType, trackerCategoryMeta } from '@data/tracking-products';
import { extractAsin } from '@utils/affiliate';

const pageSlug = 'best-dog-gps-trackers';

const cellular = getTrackersByType('cellular');
const offGrid = getTrackersByType('off-grid');
const bluetooth = getTrackersByType('bluetooth');

const tocHeadings = [
  { label: 'Quick Summary', anchor: 'summary' },
  { label: 'Cellular Trackers', anchor: 'cellular' },
  { label: 'Off-Grid GPS Systems', anchor: 'off-grid' },
  { label: 'Bluetooth Tags', anchor: 'bluetooth' },
  { label: 'Decision Guide', anchor: 'decision-guide' },
  { label: 'FAQ', anchor: 'faq' },
];

const faqs = [
  {
    question: 'What is the best GPS tracker for dogs?',
    answer:
      'There is no single best — it depends on your environment. For cities and suburbs, a cellular tracker like Fi is the most practical choice. For hiking and wilderness, a Garmin off-grid system is the only option that works without cell signal. AirTags are a budget backup layer, not a real GPS tracker.',
  },
  {
    question: 'Do I need a subscription for a dog GPS tracker?',
    answer:
      'Cellular trackers (Fi, Whistle) require a monthly subscription to access the LTE network. Garmin off-grid systems have a high upfront cost but no monthly fee. Bluetooth tags like AirTag have no subscription.',
  },
  {
    question: 'Can a dog GPS tracker work without WiFi or cell service?',
    answer:
      'Garmin off-grid GPS systems use GPS satellites and VHF radio — they work without cell service or WiFi, anywhere you can see the sky. Cellular trackers (Fi, Whistle) require LTE signal and stop reporting without it. Bluetooth tags require other devices nearby.',
  },
  {
    question: 'How accurate are dog GPS trackers?',
    answer:
      'GPS accuracy for both cellular and Garmin systems is typically within 10–30 feet under open sky. Accuracy can degrade in dense tree cover, canyons, or areas with GPS interference. Bluetooth tags are not GPS and cannot give precise real-time location — they show approximate last-seen location only.',
  },
  {
    question: 'What is the range of a GPS dog tracker?',
    answer:
      'Cellular trackers have no range limit — they report anywhere with LTE coverage, which can span hundreds of miles. Garmin off-grid systems have a line-of-sight radio range of up to 9 miles. Bluetooth tags update only when within Bluetooth range of a network device.',
  },
  {
    question: 'Is Fi collar worth it?',
    answer:
      'For everyday city and suburban use, Fi is a well-regarded option: slim, lightweight, real-time tracking, escape alerts, and geofencing. The trade-off is a monthly subscription and no functionality in no-signal areas. If you regularly hike into remote terrain, you need to supplement Fi or switch to a different system for those trips.',
  },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Best Dog GPS Trackers',
  description: 'Curated comparison of cellular, off-grid, and Bluetooth dog GPS trackers.',
  url: 'https://www.chill-dogs.com/gear/best-dog-gps-trackers/',
  numberOfItems: trackerProducts.length,
  itemListElement: trackerProducts.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.name,
    url: `https://www.chill-dogs.com/gear/best-dog-gps-trackers/#${p.id}`,
  })),
};
---

<BaseLayout
  title="Best Dog GPS Trackers: Cellular vs Off-Grid vs Bluetooth (2026)"
  description="Compare the top dog GPS trackers across three categories — cellular (Fi, Whistle), off-grid Garmin systems, and Bluetooth tags (AirTag). Honest trade-offs for each."
>
  <JsonLd slot="head" schema={itemListSchema} />

  <Hero
    title="Best Dog GPS Trackers"
    subtitle="Cellular, off-grid, and Bluetooth — three categories that solve three different problems. Know the difference before you buy."
    disclaimer="As an Amazon Associate, we earn from qualifying purchases."
    primaryCta={{ label: 'Jump to Comparison', href: '#cellular' }}
    secondaryCta={{ label: 'Decision Guide', href: '#decision-guide' }}
    pageSlug={pageSlug}
  />

  <div class="converter-content">

    <!-- Summary -->
    <section class="summary-section" id="summary">
      <div class="summary-inner">
        <h2 class="summary-heading">Quick Summary</h2>
        <p class="summary-body">
          The single most important thing to understand about dog GPS trackers: <strong>different tools solve different environments.</strong> A cellular tracker is not a worse or better version of an off-grid tracker — they solve different problems. Before picking a product, identify your terrain.
        </p>
        <div class="summary-cards">
          <div class="summary-card summary-card--pick">
            <p class="summary-card-label">City + suburbs</p>
            <p class="summary-card-pick">Fi (Best Value)</p>
            <p class="summary-card-why">GPS + LTE works in most places; escape alerts; best value for year-one cost</p>
          </div>
          <div class="summary-card">
            <p class="summary-card-label">Hiking + wilderness</p>
            <p class="summary-card-pick">Off-grid Garmin system</p>
            <p class="summary-card-why">GPS + radio; works with zero cell signal</p>
          </div>
          <div class="summary-card">
            <p class="summary-card-label">Budget backup</p>
            <p class="summary-card-pick">AirTag or Tile</p>
            <p class="summary-card-why">Not real GPS; city-only; crowd-sourced</p>
          </div>
        </div>
      </div>
    </section>

    <Toc headings={tocHeadings} pageSlug={pageSlug} />

    <!-- Cellular Trackers -->
    <section class="tracker-section" id="cellular">
      <div class="section-inner">
        <div class="section-header">
          <span class="section-tag section-tag--cellular">Cellular</span>
          <h2>{trackerCategoryMeta.cellular.title}</h2>
        </div>
        <p class="section-intro">{trackerCategoryMeta.cellular.intro}</p>

        <div class="product-grid">
          {cellular.map((product, i) => (
            <div class="product-card" id={product.id}>
              <div class="product-card-header">
                <h3 class="product-card-name">
                  {product.name}
                  {product.badge && <span class="product-badge">{product.badge}</span>}
                </h3>
                <span class="product-card-type">{product.type}</span>
              </div>
              <p class="product-card-use">{product.use_case}</p>
              <ul class="product-bullets">
                {product.bullets.map(b => <li>{b}</li>)}
              </ul>
              <div class="product-meta">
                <p class="product-signal"><strong>Signal:</strong> {product.signalNote}</p>
                {product.subscriptionNote && (
                  <p class="product-subscription"><strong>Subscription:</strong> {product.subscriptionNote}</p>
                )}
                <p class="product-best-for"><strong>Best for:</strong> {product.best_for}</p>
              </div>
              <div class="product-pros-cons">
                <div class="pros">
                  <p class="pros-heading">Pros</p>
                  <ul>
                    {product.pros.map(p => <li>{p}</li>)}
                  </ul>
                </div>
                <div class="cons">
                  <p class="cons-heading">Cons</p>
                  <ul>
                    {product.cons.map(c => <li>{c}</li>)}
                  </ul>
                </div>
              </div>
              <div class="product-cta-wrap">
                <AffiliateLink
                  href={product.affiliateUrl}
                  class="product-cta product-cta--amazon"
                  data-track="amazon_outbound_click"
                  data-asin={extractAsin(product.affiliateUrl)}
                  data-product-name={product.name}
                >
                  Check Price on Amazon
                </AffiliateLink>
              </div>
            </div>
          ))}
        </div>

        <div class="section-note">
          <p>
            <strong>When cellular trackers fail:</strong> These trackers go dark anywhere without LTE signal — remote trails, wilderness areas, rural land, and mountain terrain. If your dog runs away at a trail summit with no signal (as happened with Astro on Bishop Peak), a cellular tracker cannot help you. Read <a href={ROUTES.rhysRanAway} class="note-link">the full story</a> to understand the gap.
          </p>
        </div>

        <p class="section-cta-line">
          <a
            href={ROUTES.fiCollarReview}
            class="inline-cta"
            data-track="collector_to_converter_click"
            data-from-page={pageSlug}
            data-to-page={ROUTES.fiCollarReview}
            data-link-position="cellular-section"
          >
            Read the full Fi Collar review →
          </a>
        </p>
      </div>
    </section>

    <!-- Off-Grid -->
    <section class="tracker-section tracker-section--alt" id="off-grid">
      <div class="section-inner">
        <div class="section-header">
          <span class="section-tag section-tag--offgrid">Off-Grid GPS</span>
          <h2>{trackerCategoryMeta['off-grid'].title}</h2>
        </div>
        <p class="section-intro">{trackerCategoryMeta['off-grid'].intro}</p>

        <div class="product-grid">
          {offGrid.map((product, i) => (
            <div class="product-card" id={product.id}>
              <div class="product-card-header">
                <h3 class="product-card-name">
                  {product.name}
                  {product.badge && <span class="product-badge">{product.badge}</span>}
                </h3>
                <span class="product-card-type">{product.type}</span>
              </div>
              <p class="product-card-use">{product.use_case}</p>
              <ul class="product-bullets">
                {product.bullets.map(b => <li>{b}</li>)}
              </ul>
              <div class="product-meta">
                <p class="product-signal"><strong>Signal:</strong> {product.signalNote}</p>
                <p class="product-best-for"><strong>Best for:</strong> {product.best_for}</p>
              </div>
              <div class="product-pros-cons">
                <div class="pros">
                  <p class="pros-heading">Pros</p>
                  <ul>
                    {product.pros.map(p => <li>{p}</li>)}
                  </ul>
                </div>
                <div class="cons">
                  <p class="cons-heading">Cons</p>
                  <ul>
                    {product.cons.map(c => <li>{c}</li>)}
                  </ul>
                </div>
              </div>
              <div class="product-cta-wrap">
                <AffiliateLink
                  href={product.affiliateUrl}
                  class="product-cta product-cta--amazon"
                  data-track="amazon_outbound_click"
                  data-asin={extractAsin(product.affiliateUrl)}
                  data-product-name={product.name}
                >
                  Check Price on Amazon
                </AffiliateLink>
              </div>
            </div>
          ))}
        </div>

        <p class="section-cta-line">
          <a
            href={ROUTES.garminTracking}
            class="inline-cta"
            data-track="collector_to_converter_click"
            data-from-page={pageSlug}
            data-to-page={ROUTES.garminTracking}
            data-link-position="offgrid-section"
          >
            See the full Garmin dog tracking guide →
          </a>
        </p>
      </div>
    </section>

    <!-- Bluetooth -->
    <section class="tracker-section" id="bluetooth">
      <div class="section-inner">
        <div class="section-header">
          <span class="section-tag section-tag--bluetooth">Bluetooth Tag</span>
          <h2>{trackerCategoryMeta.bluetooth.title}</h2>
        </div>
        <p class="section-intro">{trackerCategoryMeta.bluetooth.intro}</p>

        <div class="callout callout--note">
          <p class="callout-heading">Not GPS</p>
          <p class="callout-body">
            AirTag and Tile do not use GPS satellites. They use Bluetooth crowd-sourcing — location updates only happen when another device in the network passes within Bluetooth range of the tag. In a neighborhood this can happen often. In remote terrain it may not happen at all.
          </p>
        </div>

        <div class="product-grid">
          {bluetooth.map((product, i) => (
            <div class="product-card" id={product.id}>
              <div class="product-card-header">
                <h3 class="product-card-name">
                  {product.name}
                  {product.badge && <span class="product-badge">{product.badge}</span>}
                </h3>
                <span class="product-card-type">{product.type}</span>
              </div>
              <p class="product-card-use">{product.use_case}</p>
              <ul class="product-bullets">
                {product.bullets.map(b => <li>{b}</li>)}
              </ul>
              <div class="product-meta">
                <p class="product-signal"><strong>Signal:</strong> {product.signalNote}</p>
                <p class="product-best-for"><strong>Best for:</strong> {product.best_for}</p>
              </div>
              <div class="product-pros-cons">
                <div class="pros">
                  <p class="pros-heading">Pros</p>
                  <ul>
                    {product.pros.map(p => <li>{p}</li>)}
                  </ul>
                </div>
                <div class="cons">
                  <p class="cons-heading">Cons</p>
                  <ul>
                    {product.cons.map(c => <li>{c}</li>)}
                  </ul>
                </div>
              </div>
              <div class="product-cta-wrap">
                <AffiliateLink
                  href={product.affiliateUrl}
                  class="product-cta product-cta--amazon"
                  data-track="amazon_outbound_click"
                  data-asin={extractAsin(product.affiliateUrl)}
                  data-product-name={product.name}
                >
                  Check Price on Amazon
                </AffiliateLink>
              </div>
            </div>
          ))}
        </div>

        <p class="section-cta-line">
          <a
            href={ROUTES.airtagForDogs}
            class="inline-cta"
            data-track="collector_to_converter_click"
            data-from-page={pageSlug}
            data-to-page={ROUTES.airtagForDogs}
            data-link-position="bluetooth-section"
          >
            AirTag for dogs: what it can and can't do →
          </a>
        </p>
      </div>
    </section>

    <!-- Decision Guide -->
    <section class="tracker-section tracker-section--alt" id="decision-guide">
      <div class="section-inner">
        <h2>Decision Guide: Which Tracker Fits Your Situation</h2>
        <p class="section-intro">
          Match your environment to the right category. The best tracker is the one that works where you actually are.
        </p>

        <div class="decision-table-wrap">
          <table class="decision-table">
            <thead>
              <tr>
                <th scope="col">Your situation</th>
                <th scope="col">Recommended category</th>
                <th scope="col">Key reason</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>City or suburban dog — daily walks, parks, urban areas</td>
                <td>Cellular — Fi is best value</td>
                <td>GPS + LTE works in most places; escape alerts; 12-month membership included</td>
              </tr>
              <tr>
                <td>Dog travels with you to parks with cell coverage</td>
                <td>Cellular — check coverage maps first</td>
                <td>Most campgrounds and popular parks have LTE, but verify before trip</td>
              </tr>
              <tr>
                <td>Hiking into remote or wilderness areas</td>
                <td>Off-grid Garmin system</td>
                <td>Only technology that works without any cell signal</td>
              </tr>
              <tr>
                <td>Hunting dog or field work in rural terrain</td>
                <td>Off-grid Garmin system</td>
                <td>Range, ruggedness, multi-dog tracking, no monthly fee</td>
              </tr>
              <tr>
                <td>Budget-conscious; city dog; want a backup layer</td>
                <td>Bluetooth tag (AirTag, Tile)</td>
                <td>Affordable; passive; supplement to an existing collar, not a replacement</td>
              </tr>
              <tr>
                <td>Mixed use — city most days, occasional hikes</td>
                <td>Cellular for daily use + off-grid for backcountry trips</td>
                <td>Two different tools for two different environments</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="related-guides">
          <h3 class="related-guides-heading">Go deeper on each category</h3>
          <div class="related-guide-links">
            <a
              href={ROUTES.fiCollarReview}
              class="related-guide-link"
              data-track="collector_to_converter_click"
              data-from-page={pageSlug}
              data-to-page={ROUTES.fiCollarReview}
              data-link-position="decision-guide-related"
            >
              Fi Collar Review — cellular tracking for everyday use
            </a>
            <a
              href={ROUTES.garminTracking}
              class="related-guide-link"
              data-track="collector_to_converter_click"
              data-from-page={pageSlug}
              data-to-page={ROUTES.garminTracking}
              data-link-position="decision-guide-related"
            >
              Garmin Dog Tracking Systems — off-grid wilderness use
            </a>
            <a
              href={ROUTES.airtagForDogs}
              class="related-guide-link"
              data-track="collector_to_converter_click"
              data-from-page={pageSlug}
              data-to-page={ROUTES.airtagForDogs}
              data-link-position="decision-guide-related"
            >
              AirTag for Dogs — honest assessment of Bluetooth tags
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq">
      <FAQ faqs={faqs} heading="GPS Tracker FAQ" />
    </section>

    <Disclosure />

    <InternalLinkStrip
      heading="More Dog Tracking + Safety Guides"
      links={[
        { label: 'When Rhys Ran Away', href: ROUTES.rhysRanAway },
        { label: 'Fi Collar Review', href: ROUTES.fiCollarReview },
        { label: 'Garmin Dog Tracking', href: ROUTES.garminTracking },
        { label: 'AirTag for Dogs', href: ROUTES.airtagForDogs },
        { label: 'Dog Ran Away Guide', href: ROUTES.dogRanAwaySafety },
        { label: 'Road Trip Chill Kit', href: ROUTES.roadTrip },
      ]}
      fromPage={pageSlug}
    />
  </div>
</BaseLayout>

<style>
  .converter-content {
    padding-bottom: var(--space-2xl);
  }

  /* Summary */
  .summary-section {
    padding: var(--space-2xl) var(--space-lg);
  }

  .summary-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .summary-heading {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-md);
  }

  .summary-body {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: var(--max-width-prose);
    margin-bottom: var(--space-xl);
  }

  .summary-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .summary-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  .summary-card--pick {
    border-color: var(--color-sage);
    border-width: 2px;
  }

  .summary-card-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: var(--weight-bold);
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .summary-card-pick {
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .summary-card-why {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Sections */
  .tracker-section {
    padding: var(--space-2xl) var(--space-lg);
  }

  .tracker-section--alt {
    background: var(--color-bg-alt);
  }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: var(--space-sm);
  }

  .section-header h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    margin: var(--space-xs) 0 0;
  }

  .section-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px var(--space-sm);
    border-radius: var(--radius-sm);
  }

  .section-tag--cellular {
    background: var(--color-sky);
    color: var(--color-charcoal);
  }

  .section-tag--offgrid {
    background: var(--color-sage);
    color: var(--color-charcoal);
  }

  .section-tag--bluetooth {
    background: var(--color-sand);
    color: var(--color-charcoal);
  }

  .section-intro {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: var(--max-width-prose);
    margin-bottom: var(--space-xl);
  }

  /* Product grid */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .product-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .product-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .product-card-name {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    margin: 0;
    flex: 1;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .product-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    background: var(--color-sage);
    color: #fff;
    padding: 2px var(--space-sm);
    border-radius: var(--radius-sm);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .product-card-type {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    background: var(--color-bg-alt);
    padding: 2px var(--space-sm);
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .product-card-use {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }

  .product-bullets {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .product-bullets li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    padding-left: var(--space-md);
    position: relative;
    margin-bottom: var(--space-xs);
  }

  .product-bullets li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: var(--weight-bold);
  }

  .product-meta {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .product-signal,
  .product-subscription,
  .product-best-for {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: var(--leading-normal);
  }

  .product-signal strong,
  .product-subscription strong,
  .product-best-for strong {
    color: var(--color-text);
  }

  /* Pros / Cons */
  .product-pros-cons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-md);
  }

  .pros-heading,
  .cons-heading {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
