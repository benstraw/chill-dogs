---
import { ROUTES } from '@data/routes';
import BaseLayout from '@layouts/BaseLayout.astro';
import Toc from '@components/modules/Toc.astro';
import FAQ from '@components/modules/FAQ.astro';
import Disclosure from '@components/modules/Disclosure.astro';
import CalmingDisclaimer from '@components/modules/CalmingDisclaimer.astro';
import InternalLinkStrip from '@components/modules/InternalLinkStrip.astro';
import CoolingProductCard from '@components/modules/CoolingProductCard.astro';
import CalmingProductCard from '@components/modules/CalmingProductCard.astro';
import JsonLd from '@components/JsonLd.astro';
import { getProductsByCategory } from '@data/cooling-products';
import { getCalmingProductsByCategory } from '@data/calming-products';

const pageSlug = 'rhys-road-trip-chill-kit';

const carCoolingProducts = getProductsByCategory('car-cooling');
const coolingMats = getProductsByCategory('cooling-mats').slice(0, 2);
const coolingVests = getProductsByCategory('cooling-vests').slice(0, 2);
const anxietyWraps = getCalmingProductsByCategory('anxiety-wraps').filter(p => p.id === 'thundershirt-classic');
const calmingTreats = getCalmingProductsByCategory('calming-treats').slice(0, 3);
const lickMats = getCalmingProductsByCategory('lick-mats');

const tocHeadings = [
  { label: 'The Real Setup', anchor: 'real-setup' },
  { label: 'Problem → Solution Map', anchor: 'problem-solution' },
  { label: 'Cooling the Car', anchor: 'cooling' },
  { label: 'Calming the Dog', anchor: 'calming' },
  { label: 'Road Trip Checklist', anchor: 'checklist' },
];

const roadTripFaqs = [
  {
    question: 'How do I keep a dog cool in the car without AC?',
    answer:
      'Combine passive and active methods: magnetic window shades block heat before it builds up; a clip-on fan keeps air moving over your dog; a cooling mat gives a cool surface to lie on. Schedule drives in the early morning or evening on very hot days, and stop every 1–2 hours to offer water.',
  },
  {
    question: 'Are magnetic window shades safe for dogs in the car?',
    answer:
      'Yes — they attach to the door frame with magnets, so there is nothing adhesive or loose to chew or swallow. They do reduce visibility through that window, so check that your driver\'s sightlines are clear before driving.',
  },
  {
    question: 'What is the best cooling mat for a car seat?',
    answer:
      'The Arf Pets Self Cooling Mat works well in car seats because it folds to fit crate or seat dimensions and activates on contact. For large dogs on longer trips, the K&H Cool Bed III provides more sustained cooling.',
  },
  {
    question: 'What if my dog gets carsick?',
    answer:
      'Motion sickness and anxiety can overlap. Keep the car cool and well-ventilated, limit food 2–3 hours before travel, and face your dog forward if possible. If symptoms are severe or persistent, talk to your vet — prescription options exist for dogs with significant motion sickness.',
  },
  {
    question: 'How often should we stop on a road trip with a dog?',
    answer:
      'Every 1–2 hours is a practical baseline. Dogs that are panting heavily, stressed, or in hot weather need more frequent breaks. Each stop is a good opportunity to offer water, allow a short walk, and let your dog decompress before getting back in.',
  },
  {
    question: 'Is it safe to give calming chews on a road trip?',
    answer:
      'Calming chews are generally considered safe for occasional travel use. Give them 30–45 minutes before departure so they have time to work. Consult your vet before introducing supplements, especially if your dog takes other medications or has health conditions.',
  },
  {
    question: 'Can I use a lick mat in the car?',
    answer:
      'Yes — spread peanut butter, plain yogurt, or wet food on the mat and give it to your dog during the drive. The repetitive licking can focus a restless dog and help them settle. The LUKITO mat with suction cups is especially practical since it stays in place.',
  },
  {
    question: 'What is a good minimal road trip kit for a dog?',
    answer:
      'Start with four items: magnetic window shades (passive cooling), a cooling mat (cool surface), a collapsible water bowl (hydration at every stop), and an anxiety wrap (if your dog shows travel stress). That covers the core problems without overcomplicating the setup.',
  },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: "Rhys's Road Trip Chill Kit: Cooling + Calming Essentials for Long Drives",
  description:
    'Window fan, ice cooler, magnetic shades — a practical road trip cooling and calming setup built from one real cross-country drive with a dog.',
  url: 'https://www.chill-dogs.com/travel/rhys-road-trip-chill-kit/',
  image: ['https://www.chill-dogs.com/og/travel-rhys-road-trip-chill-kit.png'],
  author: { '@type': 'Person', name: 'Benjamin Strawbridge', url: 'https://www.benstrawbridge.com/' },
  publisher: {
    '@type': 'Organization',
    name: 'Chill-Dogs',
    logo: { '@type': 'ImageObject', url: 'https://www.chill-dogs.com/images/chill-dogs-logo-padded.png', width: 700, height: 700 },
  },
};
---

<BaseLayout
  title="Rhys's Road Trip Chill Kit: Cooling + Calming Essentials for Long Drives"
  description="Window fan, magnetic shades, and a cooler of ice — a practical cooling and calming road trip setup built from a real cross-country drive. Shop cooling and calming picks for dogs."
>
  <JsonLd slot="head" schema={articleSchema} />
  <article class="collector-article container">
    <header class="article-header">
      <span class="eyebrow">Road Trip Guide</span>
      <h1>Rhys's Road Trip Chill Kit</h1>
      <p class="lede">Cooling + calming essentials for long drives — built from one real cross-country setup.</p>
    </header>

    <Toc headings={tocHeadings} pageSlug={pageSlug} />

    <div class="prose">

      <h2 id="real-setup">The Real Setup: What Rhys Uses</h2>
      <p>
        Rhys is a 7-year-old pit bull mix who did a 3,000-mile cross-country drive. No dedicated climate-controlled
        dog compartment — just a back seat, a few smart pieces of gear, and a routine that made the trip manageable.
      </p>
      <p>Here's what worked:</p>
      <ul class="story-list">
        <li>
          <strong>Window-mounted fan pointed directly at the back seat.</strong>
          The car AC hits the front seats first. A clip-on fan mounted to the headrest fixes the airflow problem
          without any complex setup.
        </li>
        <li>
          <strong>A small cooler of ice at every stop.</strong>
          Not just for cold water — Rhys would crunch ice cubes at rest stops, which provides both hydration and a
          satisfying enrichment activity. It also noticeably reduced post-stop restlessness.
        </li>
        <li>
          <strong>Magnetic window shades on both rear windows.</strong>
          Direct sun through glass can heat a back seat even with AC running. The shades knocked the seat
          temperature down significantly on west-facing afternoon drives.
        </li>
        <li>
          <strong>A stop-every-2-hours rule.</strong>
          Not negotiable. A structured routine (same order: water first, short walk, stretch, back in with a lick
          mat) reduced between-stop restlessness considerably by the second day.
        </li>
      </ul>

      <h2 id="problem-solution">Problem → Solution Map</h2>
      <p>Match the symptom to the gear that addresses it.</p>
      <div class="ps-table-wrap">
        <table class="ps-table">
          <thead>
            <tr>
              <th scope="col">Problem</th>
              <th scope="col">Root Cause</th>
              <th scope="col">Solution</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Hot back seat even with AC on</td>
              <td>Direct sun through windows; AC airflow reaches front first</td>
              <td>Magnetic window shades + clip-on rear fan</td>
            </tr>
            <tr>
              <td>Panting and restlessness mid-drive</td>
              <td>Heat + boredom + no outlet for stress</td>
              <td>Ice at rest stops, cooling mat, lick mat during drive</td>
            </tr>
            <tr>
              <td>Highway anxiety: whining, pacing</td>
              <td>Motion, noise, confinement stress</td>
              <td>Anxiety wrap before departure + calming chew routine</td>
            </tr>
            <tr>
              <td>Overstimulation at rest stops</td>
              <td>Unfamiliar environments, other dogs, traffic noise</td>
              <td>Cooling vest for the walk + calm protocol on return</td>
            </tr>
            <tr>
              <td>Refusing water at stops</td>
              <td>Stress suppresses thirst response in some dogs</td>
              <td>Offer ice cubes instead of a full bowl; familiar-smelling bowl</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 id="cooling">Cooling the Car: Temperature Management</h2>
      <p>
        Car heat is a layered problem. The most effective setup addresses all four layers: passive sun blocking,
        active airflow, a cool surface to lie on, and on-the-go cooling for rest stops.
      </p>

      <h3>1. Passive Heat Reduction — Magnetic Window Shades</h3>
      <ul>
        <li>Blocks UV and direct sun before it heats the seat — prevention is easier than cooling after the fact</li>
        <li>Installs in seconds with magnetic edges; no adhesive, no suction cups to fail at 75 mph</li>
      </ul>
      <div class="product-slot">
        {carCoolingProducts.slice(0, 1).map((product, i) => (
          <CoolingProductCard
            product={product}
            cta={{ label: 'Check Price on Amazon', href: product.amazonUrl, kind: 'amazon' }}
            position={i + 1}
            pageType="collector"
            pageSlug={pageSlug}
          />
        ))}
      </div>
      <p>
        <a href={ROUTES.coolingCar} data-track="collector_to_converter_click" data-from-page={pageSlug} data-to-page={ROUTES.coolingCar} data-link-position="section">
          See all car cooling picks →
        </a>
      </p>

      <h3>2. Active Airflow — Clip-On Car Fan</h3>
      <ul>
        <li>Fixes the AC distribution problem: pushes cool air directly to the back seat instead of the windshield</li>
        <li>Runs off any USB port or 12V adapter — no wiring required</li>
      </ul>
      <div class="product-slot">
        {carCoolingProducts.slice(1, 2).map((product, i) => (
          <CoolingProductCard
            product={product}
            cta={{ label: 'Check Price on Amazon', href: product.amazonUrl, kind: 'amazon' }}
            position={i + 2}
            pageType="collector"
            pageSlug={pageSlug}
          />
        ))}
      </div>

      <h3>3. Seat &amp; Crate Cooling — Cooling Mats</h3>
      <ul>
        <li>Gives your dog a cool surface to choose — works even when the seat itself is warm</li>
        <li>No electricity required; pressure-activated gel recharges between uses</li>
      </ul>
      <div class="product-grid-2">
        {coolingMats.map((product, i) => (
          <CoolingProductCard
            product={product}
            cta={{ label: 'Check Price on Amazon', href: product.amazonUrl, kind: 'amazon' }}
            position={i + 3}
            pageType="collector"
            pageSlug={pageSlug}
          />
        ))}
      </div>
      <p>
        <a href={ROUTES.coolingMats} data-track="collector_to_converter_click" data-from-page={pageSlug} data-to-page={ROUTES.coolingMats} data-link-position="section">
          See full cooling mats guide →
        </a>
      </p>

      <h3>4. Pit-Stop Cooling — Cooling Vests &amp; Bandanas</h3>
      <ul>
        <li>Evaporative vests keep your dog cooler during rest-stop walks so they get back in the car already cooling down</li>
        <li>Soak once, good for 30–60 minutes of walking in dry heat</li>
      </ul>
      <div class="product-grid-2">
        {coolingVests.map((product, i) => (
          <CoolingProductCard
            product={product}
            cta={{ label: 'Check Price on Amazon', href: product.amazonUrl, kind: 'amazon' }}
            position={i + 5}
            pageType="collector"
            pageSlug={pageSlug}
          />
        ))}
      </div>
      <p>
        <a href={ROUTES.coolingVests} data-track="collector_to_converter_click" data-from-page={pageSlug} data-to-page={ROUTES.coolingVests} data-link-position="section">
          See full cooling vests guide →
        </a>
      </p>

      <h2 id="calming">Calming the Dog: Temperament Management</h2>
      <p>
        Car anxiety and heat stress feed each other. A hot dog gets anxious faster; an anxious dog pants more
        and heats up faster. Address both. Here's the calming toolkit.
      </p>

      <h3>1. Compression &amp; Anxiety Wraps</h3>
      <ul>
        <li>Put it on before you start the engine — works immediately for dogs that respond to pressure</li>
        <li>No timing required: unlike chews, you get results from the first moment</li>
      </ul>
      <div class="product-slot">
        {anxietyWraps.map((product, i) => (
          <CalmingProductCard
            product={product}
            position={i + 1}
            pageType="collector"
            pageSlug={pageSlug}
          />
        ))}
      </div>
      <p>
        <a href={ROUTES.calmingCar} data-track="collector_to_converter_click" data-from-page={pageSlug} data-to-page={ROUTES.calmingCar} data-link-position="section">
          See all car calming picks →
        </a>
      </p>

      <h3>2. Calming Chews &amp; Supplements</h3>
      <ul>
        <li>Give 30–45 minutes before departure so they have time to work before you hit the highway</li>
        <li>Best used consistently on multi-day trips rather than as a last-minute fix</li>
      </ul>
      <p class="section-note">
        These are nutritional supplements, not medications. Consult your vet before introducing supplements,
        especially if your dog takes other medications.
      </p>
      <div class="product-grid-3">
        {calmingTreats.map((product, i) => (
          <CalmingProductCard
            product={product}
            position={i + 2}
            pageType="collector"
            pageSlug={pageSlug}
          />
        ))}
      </div>

      <h3>3. Routine &amp; Predictability</h3>
      <p>
        Predictability is one of the most effective calming tools for anxious dogs — and it's free. Use the same
        pre-drive routine every time: gear goes on in the same order, the same treat appears, you load up the
        same way. By day two of a multi-day trip, most dogs show noticeably less startup anxiety when the routine
        is consistent.
      </p>
      <p>
        Bring a piece of home: your dog's regular blanket or a worn T-shirt on the back seat gives them a
        familiar-smelling anchor in an unfamiliar environment.
      </p>

      <h3>4. In-Car Distraction — Lick Mats</h3>
      <ul>
        <li>Repetitive licking focuses a restless dog and can help them settle into the drive</li>
        <li>Works during the drive itself — not just before or after</li>
      </ul>
      <div class="product-grid-2">
        {lickMats.map((product, i) => (
          <CalmingProductCard
            product={product}
            position={i + 5}
            pageType="collector"
            pageSlug={pageSlug}
          />
        ))}
      </div>

      <h2 id="checklist">Road Trip Checklist</h2>
      <p>Two versions: a minimal starting kit and a full cross-country setup.</p>
      <div class="checklist-grid">
        <div class="checklist-card">
          <h3>Minimal Kit</h3>
          <p class="checklist-subtitle">Good for drives under 4 hours or budget-first builds</p>
          <ul class="checklist">
            <li>Magnetic window shades (rear windows)</li>
            <li>Cooling mat (back seat or crate)</li>
            <li>Collapsible water bowl + water jug</li>
            <li>Anxiety wrap (if travel stress is an issue)</li>
            <li>2–3 lick mat loads of peanut butter or yogurt</li>
            <li>Ice bag for the cooler</li>
          </ul>
          <a
            href={ROUTES.coolingCar}
            class="checklist-cta"
            data-track="collector_to_converter_click"
            data-from-page={pageSlug}
            data-to-page={ROUTES.coolingCar}
            data-link-position="checklist"
          >
            See the full Cooling list →
          </a>
        </div>
        <div class="checklist-card">
          <h3>Full Cross-Country Kit</h3>
          <p class="checklist-subtitle">For multi-day drives or dogs who run hot or anxious</p>
          <ul class="checklist">
            <li>Magnetic window shades</li>
            <li>Clip-on rear seat fan</li>
            <li>Cooling mat</li>
            <li>Cooling vest (for rest-stop walks)</li>
            <li>Seat cover hammock (cooler surface, safer positioning)</li>
            <li>Collapsible water bowl + ice cooler</li>
            <li>Anxiety wrap</li>
            <li>Calming chews (start 30–45 min before each driving session)</li>
            <li>Lick mat (loaded and frozen the night before)</li>
            <li>Dog's regular blanket or worn clothing for scent comfort</li>
            <li>Portable snuffle mat or chew toy for rest stops</li>
          </ul>
          <a
            href={ROUTES.calmingCar}
            class="checklist-cta checklist-cta--calm"
            data-track="collector_to_converter_click"
            data-from-page={pageSlug}
            data-to-page={ROUTES.calmingCar}
            data-link-position="checklist"
          >
            See the full Calming list →
          </a>
        </div>
      </div>

    </div>

    <FAQ faqs={roadTripFaqs} heading="Road Trip FAQ" />

    <CalmingDisclaimer variant="supplement" />

    <InternalLinkStrip
      heading="More Dog Travel Guides"
      links={[
        { label: 'Car Cooling Picks', href: ROUTES.coolingCar },
        { label: 'Cooling Mats', href: ROUTES.coolingMats },
        { label: 'Cooling Vests', href: ROUTES.coolingVests },
        { label: 'Keep a Dog Cool in a Car', href: ROUTES.coolingCarGuide },
        { label: 'Car Anxiety Picks', href: ROUTES.calmingCar },
        { label: 'All Calming Products', href: ROUTES.calmingTop },
      ]}
      fromPage={pageSlug}
    />

    <Disclosure />
  </article>
</BaseLayout>

<style>
  .collector-article {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-4xl);
    max-width: var(--max-width-prose);
  }

  .article-header {
    margin-bottom: var(--space-2xl);
  }

  .eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-text);
    margin-bottom: var(--space-sm);
  }

  .article-header h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
  }

  .lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .prose h2 {
    font-size: var(--text-2xl);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .prose h3 {
    font-size: var(--text-xl);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .prose p,
  .prose ul:not(.story-list):not(.checklist) {
    margin-bottom: var(--space-md);
    line-height: 1.7;
  }

  .prose ul:not(.story-list):not(.checklist) {
    padding-left: var(--space-lg);
  }

  .prose ul:not(.story-list):not(.checklist) li {
    margin-bottom: var(--space-sm);
  }

  .prose a {
    color: var(--color-primary);
    font-weight: var(--weight-semibold);
    text-decoration: none;
  }

  .prose a:hover {
    text-decoration: underline;
  }

  /* Story list */
  .story-list {
    max-width: var(--max-width-prose);
    margin-bottom: var(--space-lg);
    list-style: none;
    padding: 0;
  }

  .story-list li {
    line-height: 1.7;
    padding-left: var(--space-lg);
    position: relative;
    margin-bottom: var(--space-md);
    color: var(--color-text-muted);
  }

  .story-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: var(--weight-bold);
  }

  .story-list li strong {
    color: var(--color-text);
    display: block;
    margin-bottom: var(--space-xs);
  }

  /* Problem-solution table */
  .ps-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: var(--space-xl);
  }

  .ps-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    min-width: 560px;
  }

  .ps-table th {
    background: var(--color-bg-alt);
    font-weight: var(--weight-semibold);
    text-align: left;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 2px solid var(--color-border);
  }

  .ps-table td {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  .ps-table td:first-child {
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .ps-table td:last-child {
    color: var(--color-accent-text);
    font-weight: var(--weight-medium);
  }

  /* Supplement note */
  .section-note {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    border-left: 3px solid var(--color-sage);
    padding-left: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  /* Product slots */
  .product-slot {
    margin: var(--space-lg) 0;
    max-width: 480px;
  }

  .product-grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    margin: var(--space-lg) 0;
  }

  .product-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin: var(--space-lg) 0;
  }

  /* Checklist */
  .checklist-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .checklist-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
  }

  .checklist-card h3 {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-xs);
    margin-top: 0;
  }

  .checklist-subtitle {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    font-style: italic;
  }

  .checklist {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    list-style: none;
    padding: 0;
    flex: 1;
    margin-bottom: var(--space-lg);
  }

  .checklist li {
    padding-left: var(--space-md);
    position: relative;
    margin-bottom: var(--space-sm);
  }

  .checklist li::before {
    content: '☐';
    position: absolute;
    left: 0;
    color: var(--color-text-muted);
  }

  .checklist-cta {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    text-decoration: none;
    margin-top: auto;
  }

  .checklist-cta:hover {
    text-decoration: underline;
  }

  .checklist-cta--calm {
    color: var(--color-accent-text);
  }

  @media (max-width: 1024px) {
    .product-grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .checklist-grid,
    .product-grid-2,
    .product-grid-3 {
      grid-template-columns: 1fr;
    }

    .product-slot {
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .article-header h1 {
      font-size: var(--text-3xl);
    }
  }
</style>
