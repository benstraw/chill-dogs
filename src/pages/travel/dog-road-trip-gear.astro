---
import { Image } from 'astro:assets';
import { ROUTES } from '@data/routes';
import BaseLayout from '@layouts/BaseLayout.astro';
import Toc from '@components/modules/Toc.astro';
import FAQ from '@components/modules/FAQ.astro';
import Disclosure from '@components/modules/Disclosure.astro';
import CalmingDisclaimer from '@components/modules/CalmingDisclaimer.astro';
import InternalLinkStrip from '@components/modules/InternalLinkStrip.astro';
import CoolingProductCard from '@components/modules/CoolingProductCard.astro';
import CalmingProductCard from '@components/modules/CalmingProductCard.astro';
import RelaxationProductCard from '@components/modules/RelaxationProductCard.astro';
import JsonLd from '@components/JsonLd.astro';
import { getProductsByCategory } from '@data/cooling-products';
import { getCalmingProductsByCategory } from '@data/calming-products';
import { getRelaxationProductsByCategory } from '@data/relaxation-products';

import imgOldCar from '../../images/rhys-road-trip/20250629_131343.jpg';
import imgFanCooler from '../../images/rhys-road-trip/20250630_164216~2.jpg';
import imgIceCooler from '../../images/rhys-road-trip/20250702_124249.jpg';
import imgNamesakeMagnet from '../../images/rhys-road-trip/20250703_110230~2.jpg';
import imgDogPark from '../../images/rhys-road-trip/20250709_190632~2.jpg';
import imgSnuggled from '../../images/rhys-road-trip/20250709_233517~2.jpg';
import imgCoffeeStop from '../../images/rhys-road-trip/20250711_195946~2.jpg';
import imgNowhere from '../../images/rhys-road-trip/20250713_014356~2.jpg';

const pageSlug = 'dog-road-trip-gear';

const carCoolingProducts = getProductsByCategory('car-cooling');
const waterBowl = carCoolingProducts.filter(p => p.id === 'ohmo-spill-proof-bowl');
const anxietyWraps = getCalmingProductsByCategory('anxiety-wraps').filter(p => p.id === 'thundershirt-classic');
const greenies = getCalmingProductsByCategory('calming-treats').filter(p => p.id === 'greenies-calming-chews');
const travelBeds = getRelaxationProductsByCategory('travel-beds').filter(p => p.id === 'onetigris-travel-dog-bed');

const tocHeadings = [
  { label: 'The Real Setup', anchor: 'real-setup' },
  { label: 'Problem → Solution Map', anchor: 'problem-solution' },
  { label: 'Cooling the Car', anchor: 'cooling' },
  { label: 'Calming the Dog', anchor: 'calming' },
  { label: 'Comfort Off the Road', anchor: 'comfort' },
  { label: 'Road Trip Checklist', anchor: 'checklist' },
];

const roadTripFaqs = [
  {
    question: 'How do I keep a dog cool in the car without AC?',
    answer:
      'Combine passive and active methods: magnetic window shades block heat before it builds up; a clip-on fan keeps air moving over your dog. Schedule drives in the early morning or evening on very hot days, and stop every 1–2 hours to offer water and ice.',
  },
  {
    question: 'Are magnetic window shades safe for dogs in the car?',
    answer:
      'Yes — they attach to the door frame with magnets, so there is nothing adhesive or loose to chew or swallow. They do reduce visibility through that window, so check that your driver\'s sightlines are clear before driving.',
  },
  {
    question: 'What if my dog gets carsick?',
    answer:
      'Motion sickness and anxiety can overlap. Keep the car cool and well-ventilated, limit food 2–3 hours before travel, and face your dog forward if possible. If symptoms are severe or persistent, talk to your vet — prescription options exist for dogs with significant motion sickness.',
  },
  {
    question: 'How often should we stop on a road trip with a dog?',
    answer:
      'Every 1–2 hours is a practical baseline. Dogs that are panting heavily, stressed, or in hot weather need more frequent breaks. Each stop is a good opportunity to offer water and ice, allow a short walk, and let your dog decompress before getting back in.',
  },
  {
    question: 'Is it safe to give calming chews on a road trip?',
    answer:
      'Calming chews are generally considered safe for occasional travel use. Give them 30–45 minutes before departure so they have time to work. Consult your vet before introducing supplements, especially if your dog takes other medications or has health conditions.',
  },
  {
    question: 'What is a good minimal road trip kit for a dog?',
    answer:
      'Start with four items: magnetic window shades (passive cooling), a clip-on fan (active airflow), a collapsible water bowl and ice cooler (hydration at every stop), and an anxiety wrap if your dog shows travel stress. That covers the core problems without overcomplicating the setup.',
  },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: "Dog Road Trip Gear: Cooling & Calming Essentials That Work",
  description:
    'Dog road trip gear tested on a 3,000-mile cross-country drive — cooling fan, magnetic shades, water bowl, and calming essentials for long drives with dogs.',
  url: 'https://www.chill-dogs.com/travel/dog-road-trip-gear/',
  image: ['https://www.chill-dogs.com/og/travel-rhys-road-trip-chill-kit.png'],
  author: { '@type': 'Person', name: 'Benjamin Strawbridge', url: 'https://www.benstrawbridge.com/' },
  publisher: {
    '@type': 'Organization',
    name: 'Chill-Dogs',
    logo: { '@type': 'ImageObject', url: 'https://www.chill-dogs.com/images/chill-dogs-logo-padded.png', width: 700, height: 700 },
  },
};
---

<BaseLayout
  title="Dog Road Trip Gear: Cooling & Calming Essentials That Work"
  ogTitle="Rhys's Road Trip Chill Kit | Dog Cooling & Calming"
  description="Dog road trip gear tested on a 3,000-mile cross-country drive — cooling fan, magnetic shades, water bowl, and calming essentials for long drives with dogs."
>
  <JsonLd slot="head" schema={articleSchema} />
  <article class="collector-article container">
    <header class="article-header">
      <span class="eyebrow">Road Trip Guide</span>
      <h1>Rhys's Road Trip Gear: Cooling &amp; Calming for Long Drives</h1>
      <p class="lede">Dog road trip gear that actually holds up — cooling and calming essentials from one real 3,000-mile cross-country drive.</p>
    </header>

    <Toc headings={tocHeadings} pageSlug={pageSlug} />

    <div class="prose">

      <h2 id="real-setup">The Real Setup: What Rhys Uses</h2>
      <p>
        Rhys is a 7-year-old pit bull mix who completed a 3,000-mile cross-country drive from California to
        New York in summer 2025. No dedicated climate-controlled dog compartment — just a back seat, a few
        smart pieces of dog road trip gear, and a routine that held together for two weeks on the road. One
        highlight stop: the Petrified Forest in Arizona, where an old car rusting in the desert reminded us
        that not every road trip ends where you planned.
      </p>

      <figure class="trip-photo">
        <Image
          src={imgOldCar}
          alt="Vintage rusted car at Petrified Forest Arizona on a cross-country dog road trip"
          width={900}
          quality={80}
        />
        <figcaption>Somewhere in the Petrified Forest, Arizona. Some road trips end here.</figcaption>
      </figure>

      <p>Here's what worked:</p>
      <ul class="story-list">
        <li>
          <strong>Window-mounted fan pointed directly at the back seat.</strong>
          The car AC hits the front seats first. A clip-on fan mounted to the headrest fixes the airflow problem
          without any complex setup.
        </li>
        <li>
          <strong>A small cooler of ice at every stop.</strong>
          Not just for cold water — Rhys would crunch ice cubes at rest stops, which provides both hydration and a
          satisfying enrichment activity. It also noticeably reduced post-stop restlessness.
        </li>
        <li>
          <strong>Magnetic window shades on both rear windows.</strong>
          Direct sun through glass can heat a back seat even with AC running. The shades knocked the seat
          temperature down significantly on west-facing afternoon drives.
        </li>
        <li>
          <strong>A spill-proof collapsible water bowl.</strong>
          Car rides are bumpy. A regular bowl becomes a wet-seat problem fast. The OHMO bowl holds its water
          over rough roads, collapses flat between stops, and fits in any door panel or bag.
        </li>
        <li>
          <strong>A packable travel bed for every stop.</strong>
          Hotel floors, rest-stop grass, a friend's spare room — the OneTigris bed rolls out in seconds anywhere.
          Rhys settles faster when he lands on something that smells and feels like his own surface, no matter where we stopped.
        </li>
        <li>
          <strong>A stop-every-2-hours rule.</strong>
          Not negotiable. A structured routine (same order: water first, short walk, stretch, back in)
          reduced between-stop restlessness considerably by the second day.
        </li>
      </ul>

      <figure class="trip-photo">
        <Image
          src={imgFanCooler}
          alt="Pit bull dog in car back seat with clip-on cooling fan and travel cooler for dog road trip"
          width={900}
          quality={80}
        />
        <figcaption>The back seat setup: fan, cooler, and co-pilot Woodstock.</figcaption>
      </figure>

      <figure class="trip-photo">
        <Image
          src={imgIceCooler}
          alt="Dog eating ice from cooler at road trip rest stop for cooling and hydration"
          width={900}
          quality={80}
        />
        <figcaption>Ice from the cooler — more enriching than a water bowl, and he never said no.</figcaption>
      </figure>

      <h2 id="problem-solution">Problem → Solution Map</h2>
      <p>Here's how the problems actually showed up on the drive, and what addressed each one.</p>
      <div class="ps-table-wrap">
        <table class="ps-table">
          <thead>
            <tr>
              <th scope="col">Problem</th>
              <th scope="col">Root Cause</th>
              <th scope="col">Solution</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Hot back seat even with AC on</td>
              <td>Direct sun through windows; AC airflow reaches front first</td>
              <td>Magnetic window shades + clip-on rear fan</td>
            </tr>
            <tr>
              <td>Panting and restlessness mid-drive</td>
              <td>Heat + boredom + no outlet for stress</td>
              <td>Ice at rest stops; calming chews for rough stretches</td>
            </tr>
            <tr>
              <td>Highway anxiety: whining, pacing</td>
              <td>Motion, noise, confinement stress</td>
              <td>Anxiety wrap before departure + just-in-case calming chews</td>
            </tr>
            <tr>
              <td>Refusing water at stops</td>
              <td>Stress suppresses thirst response in some dogs</td>
              <td>Offer ice cubes instead of a full bowl; familiar-smelling bowl</td>
            </tr>
          </tbody>
        </table>
      </div>

      <figure class="trip-photo">
        <Image
          src={imgNamesakeMagnet}
          alt="Pit bull dog posing next to souvenir magnet at hotel stop during cross-country road trip"
          width={900}
          quality={80}
        />
        <figcaption>Posing next to his own brand of magnet.</figcaption>
      </figure>

      <h2 id="cooling">Cooling the Car: Temperature Management</h2>
      <p class="section-summary">
        The core problem: car AC airflow reaches the front seats first. Dogs in the back need passive sun
        blocking and active airflow to stay cool — the two work together, not interchangeably.
      </p>
      <p>
        Car heat is a layered problem. The most effective setup addresses it passively and actively — block the
        sun before it heats the seat, then move the air so your dog actually benefits from the AC. The AKC
        notes that a parked car can reach 100°F in under 20 minutes on a 70°F day; keeping air moving while
        driving matters just as much as what happens at rest stops.
      </p>

      <h3>1. Passive Heat Reduction — Magnetic Window Shades</h3>
      <ul>
        <li>Blocks UV and direct sun before it heats the seat — prevention is easier than cooling after the fact</li>
        <li>Installs in seconds with magnetic edges; no adhesive, no suction cups to fail at 75 mph</li>
      </ul>
      <div class="product-slot">
        {carCoolingProducts.slice(0, 1).map((product, i) => (
          <CoolingProductCard
            product={product}
            cta={{ label: 'Check Price on Amazon', href: product.amazonUrl, kind: 'amazon' }}
            position={i + 1}
            pageType="collector"
            pageSlug={pageSlug}
          />
        ))}
      </div>
      <p>
        <a href={ROUTES.coolingCar} data-track="collector_to_converter_click" data-from-page={pageSlug} data-to-page={ROUTES.coolingCar} data-link-position="section">
          See all car cooling picks →
        </a>
      </p>

      <h3>2. Active Airflow — Clip-On Car Fan</h3>
      <ul>
        <li>Fixes the AC distribution problem: pushes cool air directly to the back seat instead of the windshield</li>
        <li>Runs off any USB port or 12V adapter — no wiring required</li>
      </ul>
      <div class="hero-product">
        <span class="hero-badge">Rhys Approved Product</span>
        <div class="product-slot">
          {carCoolingProducts.slice(1, 2).map((product, i) => (
            <CoolingProductCard
              product={product}
              cta={{ label: 'Check Price on Amazon', href: product.amazonUrl, kind: 'amazon' }}
              position={i + 2}
              pageType="collector"
              pageSlug={pageSlug}
            />
          ))}
        </div>
      </div>

      <h3>3. Hydration at Every Stop — Collapsible Water Bowl</h3>
      <ul>
        <li>Spill-proof design keeps water in the bowl on bumpy roads — not on the seat</li>
        <li>Collapses flat; lives in the door panel or travel bag between stops</li>
      </ul>
      <div class="hero-product">
        <span class="hero-badge">Rhys Approved Product</span>
        <div class="product-slot">
          {waterBowl.map((product, i) => (
            <CoolingProductCard
              product={product}
              cta={{ label: 'Check Price on Amazon', href: product.amazonUrl, kind: 'amazon' }}
              position={i + 3}
              pageType="collector"
              pageSlug={pageSlug}
            />
          ))}
        </div>
      </div>

      <div class="geo-callout">
        <p><strong>Stop every 2 hours, without exception.</strong> Dogs can't regulate body temperature as efficiently as humans during sustained car travel. A structured stop every 2 hours — water first, short walk, a few minutes to decompress — significantly reduces heat buildup and anxiety over a multi-day drive.</p>
      </div>

      <div class="geo-callout">
        <p><strong>Ice cubes are enrichment, not just hydration.</strong> Many dogs that refuse water at rest stops will eagerly crunch ice. The physical act of crunching provides enrichment that reduces restlessness during the next leg — and delivers hydration at the same time.</p>
      </div>

      <h2 id="calming">Calming the Dog: Temperament Management</h2>
      <p class="section-summary">
        The core problem: heat and anxiety compound each other on the road. A hot dog gets anxious faster;
        an anxious dog pants more and overheats faster. Addressing both together is more effective than treating
        them separately.
      </p>
      <p>
        Car anxiety and heat stress feed each other. A hot dog gets anxious faster; an anxious dog pants more
        and heats up faster. Address both. Here's the calming toolkit.
      </p>

      <figure class="trip-photo">
        <Image
          src={imgDogPark}
          alt="Dog socializing at dog park during cross-country road trip rest stop"
          width={900}
          quality={80}
        />
        <figcaption>Don't skip socialization. A dog park stop mid-trip can reset the whole mood for the next leg.</figcaption>
      </figure>

      <h3>1. Compression &amp; Anxiety Wraps</h3>
      <p>
        The AKC describes anxiety wraps as working through gentle, constant pressure — similar to sustained
        physical contact — which is effective for many dogs experiencing travel or situational stress.
      </p>
      <ul>
        <li>Put it on before you start the engine — works immediately for dogs that respond to pressure</li>
        <li>No timing required: unlike chews, you get results from the first moment</li>
      </ul>
      <div class="product-slot">
        {anxietyWraps.map((product, i) => (
          <CalmingProductCard
            product={product}
            position={i + 1}
            pageType="collector"
            pageSlug={pageSlug}
          />
        ))}
      </div>
      <p>
        <a href={ROUTES.calmingCar} data-track="collector_to_converter_click" data-from-page={pageSlug} data-to-page={ROUTES.calmingCar} data-link-position="section">
          See all car calming picks →
        </a>
      </p>

      <h3>2. Routine &amp; Predictability</h3>
      <p>
        Predictability is one of the most effective calming tools for anxious dogs — and it's free. Use the same
        pre-drive routine every time: gear goes on in the same order, the same treat appears, you load up the
        same way. By day two of a multi-day trip, most dogs show noticeably less startup anxiety when the routine
        is consistent.
      </p>
      <p>
        Bring a piece of home: your dog's regular blanket or a worn T-shirt on the back seat gives them a
        familiar-smelling anchor in an unfamiliar environment.
      </p>

      <figure class="trip-photo">
        <Image
          src={imgCoffeeStop}
          alt="Dog drinking water from collapsible bowl at road trip rest stop"
          width={900}
          quality={80}
        />
        <figcaption>When we stop for coffee, Rhys stops for H₂O. Every stop, same routine.</figcaption>
      </figure>

      <h3>3. Just-in-Case Treats — Calming Chews</h3>
      <p>
        Rhys didn't need these every day, but having them on hand mattered. A particularly rough stretch of
        highway, a noisy truck stop, an unfamiliar motel — sometimes you want a low-stakes option in your back
        pocket before things escalate. They're nutritional supplements, not medications, so no dramatic
        intervention — just something to take the edge off. If your dog is already on something, loop in your
        vet before adding anything new.
      </p>
      <div class="product-slot">
        {greenies.map((product, i) => (
          <CalmingProductCard
            product={product}
            position={i + 2}
            pageType="collector"
            pageSlug={pageSlug}
          />
        ))}
      </div>

      <h2 id="comfort">The Bed That Made Every Stop Feel Like Home</h2>
      <p>
        The drive is the hard part — but where Rhys landed at the end of each day mattered just as much.
        Hotel carpet is unfamiliar. A folded blanket on the floor isn't a bed. What actually worked was
        giving him the same surface every single night, wherever we stopped.
      </p>
      <p>
        The OneTigris travel bed packs to near water-bottle size and rolls out in about ten seconds. By
        night two of the trip, Rhys was walking straight to it the moment we got into a room — no sniffing
        the perimeter, no restless circling. He just laid down. That's the whole point.
      </p>

      <figure class="trip-photo">
        <Image
          src={imgSnuggled}
          alt="Dog resting on travel bed with blanket at road trip overnight hotel stop"
          width={900}
          quality={80}
        />
        <figcaption>Same bed, every stop. Familiar surface makes a big difference after long days in the car.</figcaption>
      </figure>

      <div class="hero-product">
        <span class="hero-badge">Rhys Approved Product</span>
        <div class="product-slot">
          {travelBeds.map((product, i) => (
            <RelaxationProductCard
              product={product}
              position={i + 1}
              pageSlug={pageSlug}
            />
          ))}
        </div>
      </div>

      <figure class="trip-photo">
        <Image
          src={imgNowhere}
          alt="Road sign in the middle of nowhere on a cross-country dog road trip"
          width={900}
          quality={80}
        />
        <figcaption>You are nowhere. It's gotta be somewhere.</figcaption>
      </figure>

      <h2 id="checklist">Road Trip Checklist</h2>
      <p>Two versions: a minimal starting kit and a full cross-country setup.</p>
      <div class="checklist-grid">
        <div class="checklist-card">
          <h3>Minimal Kit</h3>
          <p class="checklist-subtitle">Good for drives under 4 hours or budget-first builds</p>
          <ul class="checklist">
            <li>Magnetic window shades (rear windows)</li>
            <li>Clip-on fan (rear headrest)</li>
            <li>Collapsible water bowl + water jug</li>
            <li>Anxiety wrap (if travel stress is an issue)</li>
            <li>Ice bag for the cooler</li>
          </ul>
          <a
            href={ROUTES.coolingCar}
            class="checklist-cta"
            data-track="collector_to_converter_click"
            data-from-page={pageSlug}
            data-to-page={ROUTES.coolingCar}
            data-link-position="checklist"
          >
            See the full Cooling list →
          </a>
        </div>
        <div class="checklist-card">
          <h3>Full Cross-Country Kit</h3>
          <p class="checklist-subtitle">For multi-day drives or dogs who run hot or anxious</p>
          <ul class="checklist">
            <li>Magnetic window shades</li>
            <li>Clip-on rear seat fan</li>
            <li>Collapsible water bowl + ice cooler</li>
            <li>Anxiety wrap</li>
            <li>Calming chews (just in case)</li>
            <li>OneTigris travel bed (packs to the size of a water bottle)</li>
            <li>Dog's regular blanket or worn clothing for scent comfort</li>
            <li>Portable chew toy or snuffle mat for rest stops</li>
          </ul>
          <a
            href={ROUTES.calmingCar}
            class="checklist-cta checklist-cta--calm"
            data-track="collector_to_converter_click"
            data-from-page={pageSlug}
            data-to-page={ROUTES.calmingCar}
            data-link-position="checklist"
          >
            See the full Calming list →
          </a>
        </div>
      </div>

    </div>

    <FAQ faqs={roadTripFaqs} heading="Road Trip FAQ" />

    <CalmingDisclaimer variant="supplement" />

    <InternalLinkStrip
      heading="More Dog Travel Guides"
      links={[
        { label: 'Car Cooling Picks', href: ROUTES.coolingCar },
        { label: 'Car Anxiety Picks', href: ROUTES.calmingCar },
        { label: 'All Calming Products', href: ROUTES.calmingTop },
      ]}
      fromPage={pageSlug}
    />

    <Disclosure />
  </article>
</BaseLayout>

<style>
  .collector-article {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-4xl);
    max-width: var(--max-width-prose);
  }

  .article-header {
    margin-bottom: var(--space-2xl);
  }

  .eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-text);
    margin-bottom: var(--space-sm);
  }

  .article-header h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
  }

  .lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .prose h2 {
    font-size: var(--text-2xl);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .prose h3 {
    font-size: var(--text-xl);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .prose p,
  .prose ul:not(.story-list):not(.checklist) {
    margin-bottom: var(--space-md);
    line-height: 1.7;
  }

  .prose ul:not(.story-list):not(.checklist) {
    padding-left: var(--space-lg);
  }

  .prose ul:not(.story-list):not(.checklist) li {
    margin-bottom: var(--space-sm);
  }

  .prose a {
    color: var(--color-primary);
    font-weight: var(--weight-semibold);
    text-decoration: none;
  }

  .prose a:hover {
    text-decoration: underline;
  }

  /* Story list */
  .story-list {
    max-width: var(--max-width-prose);
    margin-bottom: var(--space-lg);
    list-style: none;
    padding: 0;
  }

  .story-list li {
    line-height: 1.7;
    padding-left: var(--space-lg);
    position: relative;
    margin-bottom: var(--space-md);
    color: var(--color-text-muted);
  }

  .story-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: var(--weight-bold);
  }

  .story-list li strong {
    color: var(--color-text);
    display: block;
    margin-bottom: var(--space-xs);
  }

  /* Trip photos */
  .trip-photo {
    margin: var(--space-2xl) 0;
  }

  .trip-photo img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    display: block;
  }

  .trip-photo figcaption {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: var(--space-sm);
    text-align: center;
  }

  /* Problem-solution table */
  .ps-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: var(--space-xl);
  }

  .ps-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    min-width: 560px;
  }

  .ps-table th {
    background: var(--color-bg-alt);
    font-weight: var(--weight-semibold);
    text-align: left;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 2px solid var(--color-border);
  }

  .ps-table td {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  .ps-table td:first-child {
