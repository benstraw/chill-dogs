---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroExperiment from '@components/modules/HeroExperiment.astro';
import CalmingHubHeroFireworks from '@components/modules/CalmingHubHeroFireworks.astro';
import CalmingHubBody from '@components/modules/CalmingHubBody.astro';
import type { HeroVariant } from '@components/modules/HeroExperiment.astro';

export function getStaticPaths() {
  const variants: HeroVariant[] = ['a', 'b', 'c', 'd', 'e', 'f', 'g', 'h'];
  return variants.map((v) => ({ params: { variant: v } }));
}

const { variant } = Astro.params as { variant: HeroVariant };

/**
 * Variant pages are experiment copies of /calming/.
 * - canonical: /calming/ (prevents SEO duplication)
 * - robots: noindex, follow (crawl links but don't index)
 */
const canonicalUrl = new URL('/calming/', Astro.site).href;
---

<BaseLayout
  title="Calm & Comfort"
  description="Explore Chill-Dogs calming guides for anxious dogs, including ThunderShirt, calming chews, lick mats, and snuffle mats."
  canonicalUrl={canonicalUrl}
  navAccent="var(--color-sage)"
>
  <meta slot="head" name="robots" content="noindex, follow" />

  {variant === 'h' ? (
    <CalmingHubHeroFireworks
      headline="Calm Starts Here"
      subhead="Anxiety vests, calming chews, and enrichment distractions for nervous dogs"
      primaryCta={{ label: 'See top calming picks', href: '/calming/best-calming-products-for-anxious-dogs/' }}
      secondaryCta={{ label: 'What to try first', href: '/best-thundershirt-alternatives/' }}
    />
  ) : (
    <HeroExperiment
      variant={variant}
      theme="calming"
      headline="Calm Starts Here"
      subhead="Anxiety vests, calming chews, and enrichment distractions for nervous dogs"
      primaryCta={{ label: 'See top calming picks', href: '/calming/best-calming-products-for-anxious-dogs/' }}
      secondaryCta={{ label: 'What to try first', href: '/best-thundershirt-alternatives/' }}
    />
  )}

  <CalmingHubBody />
</BaseLayout>
