---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { createSitemapPage, staticSitemapSections, type SitemapSection } from '@data/content-sitemap';

const articleEntries = await getCollection('articles');
const articlePages = articleEntries
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((entry) =>
    createSitemapPage({
      baseTitle: entry.data.title,
      ogTitle: entry.data.ogTitle,
      description: entry.data.description,
      ogImage: entry.data.ogImage,
      href: entry.data.canonicalPath,
      pageType: 'collector',
      collectorSubtype: 'article',
    })
  );

const articlesSection: SitemapSection = {
  title: 'Articles (from collection)',
  description: 'Article collectors auto-discovered from the MDX content collection — sorted by publish date.',
  pages: articlePages,
};

const allSections = [staticSitemapSections[0], articlesSection, ...staticSitemapSections.slice(1)];
const totalPages = allSections.reduce((count, section) => count + section.pages.length, 0);
---

<BaseLayout
  title="Content Sitemap"
  description="Hidden editor-facing sitemap for working through current chill-dogs page titles and routes."
  noindex={true}
>
  <section class="content-sitemap container">
    <div class="intro">
      <p class="eyebrow">Hidden Editor Page</p>
      <h1>Content sitemap</h1>
      <p class="lede">
        A working list of current page titles and routes for editorial review. This page is set to noindex and is intended for internal use only.
      </p>
      <p class="meta">{totalPages} linked pages across {allSections.length} sections.</p>
    </div>

    <div class="section-list">
      {allSections.map((section) => (
        <section class="group">
          <header class="group-header">
            <h2>{section.title}</h2>
            <p>{section.description}</p>
          </header>

          <ul class="page-list">
            {section.pages.map((page) => (
              <li class="page-row" data-share-preview-row data-href={page.href}>
                <a href={page.href} class="page-thumb-link" aria-hidden="true" tabindex="-1">
                  <img
                    src={page.preview.image}
                    alt=""
                    loading="lazy"
                    class="page-thumb"
                    data-share-image
                  />
                </a>
                <div class="page-copy">
                  <a href={page.href} data-share-title>{page.preview.title}</a>
                  <p class="page-preview-description" data-share-description>{page.preview.description}</p>
                  <code>{page.href}</code>
                </div>
                <span class={`page-type page-type--${page.pageType}${page.collectorSubtype ? `-${page.collectorSubtype}` : ''}`}>
                  {page.pageType}{page.collectorSubtype ? ` · ${page.collectorSubtype}` : ''}
                </span>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .content-sitemap {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-4xl);
  }

  .intro {
    max-width: 48rem;
    margin-bottom: var(--space-2xl);
  }

  .eyebrow {
    margin: 0 0 var(--space-sm);
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .intro h1 {
    margin-bottom: var(--space-md);
    font-size: var(--text-4xl);
  }

  .lede,
  .meta,
  .group-header p,
  code {
    color: var(--color-text-muted);
  }

  .meta {
    margin-top: var(--space-md);
    font-size: var(--text-sm);
  }

  .section-list {
    display: grid;
    gap: var(--space-xl);
  }

  .group {
    padding: var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .group-header {
    margin-bottom: var(--space-lg);
  }

  .group-header h2 {
    margin-bottom: var(--space-xs);
    font-size: var(--text-2xl);
  }

  .page-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-md);
  }

  .page-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .page-row:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .page-thumb-link {
    flex-shrink: 0;
    width: 10rem;
    text-decoration: none;
  }

  .page-thumb {
    display: block;
    width: 100%;
    aspect-ratio: 1.91 / 1;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: linear-gradient(180deg, rgba(135, 183, 199, 0.14), rgba(245, 240, 232, 0.9));
  }

  .page-copy {
    display: grid;
    gap: 0.25rem;
    min-width: 0;
    flex: 1 1 auto;
  }

  .page-copy a {
    color: var(--color-text);
    font-weight: 700;
    text-decoration: none;
  }

  .page-copy a:hover,
  .page-copy a:focus-visible {
    text-decoration: underline;
  }

  .page-preview-description {
    margin: 0;
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  code {
    font-size: var(--text-sm);
  }

  .page-type {
    flex-shrink: 0;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .page-type--converter {
    background: rgba(201, 138, 82, 0.14);
    color: #8a4e1d;
  }

  .page-type--collector {
    background: rgba(104, 160, 133, 0.16);
    color: #2e6448;
  }

  .page-type--collector-section {
    background: rgba(104, 160, 133, 0.16);
    color: #2e6448;
  }

  .page-type--collector-article {
    background: rgba(104, 160, 133, 0.28);
    color: #1f4f35;
    font-style: italic;
  }

  .page-type--attractor {
    background: rgba(95, 150, 196, 0.16);
    color: #24587e;
  }

  .page-type--informer {
    background: rgba(78, 86, 98, 0.12);
    color: #3f4a56;
  }

  @media (max-width: 800px) {
    .page-row {
      align-items: flex-start;
      flex-direction: column;
    }

    .page-thumb-link {
      width: min(14rem, 100%);
    }
  }
</style>
