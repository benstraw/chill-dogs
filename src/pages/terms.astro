---
import { ROUTES } from '@data/routes';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Use" description="Terms of use for Chill-Dogs website." noindex>
  <section class="legal container">
    <div class="prose">
      <h1>Terms of Use</h1>
      <p><em>Last updated: February 2026</em></p>

      <p>
        By accessing and using chill-dogs.com ("the Site"), you agree to be bound by these Terms of Use. If you do not agree with any part of these terms, please do not use the Site.
      </p>

      <h2>Content</h2>
      <p>
        All content on this site is provided for informational purposes only. Product recommendations represent our honest opinions based on research. We make no guarantees about the accuracy, completeness, or reliability of any information on the Site.
      </p>

      <h2>Affiliate Links</h2>
      <p>
        This site contains affiliate links to Amazon.com and potentially other retailers. When you click on these links and make a purchase, we may earn a commission. This does not affect the price you pay. See our <a href={ROUTES.affiliateDisclosure}>Affiliate Disclosure</a> for more details.
      </p>

      <h2>Intellectual Property</h2>
      <p>
        The content, design, and branding of Chill-Dogs are the property of Chill-Dogs and are protected by applicable copyright and trademark laws. You may not reproduce, distribute, or create derivative works without our prior written consent.
      </p>

      <h2>Limitation of Liability</h2>
      <p>
        Chill-Dogs shall not be liable for any damages arising from the use of this site or the products recommended herein. All purchases are made directly through third-party retailers, and any issues should be addressed with those retailers directly.
      </p>

      <h2>Changes</h2>
      <p>
        We reserve the right to modify these terms at any time. Continued use of the Site constitutes acceptance of any changes.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about these terms? <a href={ROUTES.contact}>Contact us</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .legal {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-4xl);
  }

  .legal h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-xl);
  }
</style>
