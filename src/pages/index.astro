---
import { ROUTES } from '@data/routes';
import BaseLayout from '@layouts/BaseLayout.astro';
import ComingSoon from '@components/ComingSoon.astro';
import HomepageHero from '@components/modules/HomepageHero.astro';
import HomepageBody from '@components/modules/HomepageBody.astro';
import JsonLd from '@components/JsonLd.astro';

const maintenanceMode = !!import.meta.env.MAINTENANCE_MODE;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'chill-dogs',
  url: 'https://www.chill-dogs.com/',
  description: 'Curated cooling and calming picks to help your dog feel better fast — from summer heat relief to anxiety-friendly comfort.',
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'chill-dogs',
  url: 'https://www.chill-dogs.com/',
  logo: 'https://www.chill-dogs.com/favicon.ico',
};
---

{maintenanceMode ? (
  <BaseLayout
    title="chill-dogs Coming Soon"
    description="chill-dogs is getting ready to launch with cooling, calming, and travel picks for dogs."
    noindex={true}
    hideChrome={true}
  >
    <ComingSoon />
  </BaseLayout>
) : (
  <BaseLayout
    title="Home"
    description="Curated cooling and calming picks to help your dog feel better fast — from summer heat relief to anxiety-friendly comfort."
  >
    <JsonLd slot="head" schema={websiteSchema} />
    <JsonLd slot="head" schema={orgSchema} />
    <HomepageHero variant="v1" />

    <section class="comfort-block">
      <div class="comfort-block-inner container">
        <p class="comfort-tagline">Settle in.</p>
        <h2 class="comfort-heading">Comfort &amp; Rest</h2>
        <p class="comfort-description">The right bed changes everything. Calming beds, orthopedic beds, and rest guides for dogs who deserve proper support.</p>
        <a href={ROUTES.comfortHub} class="comfort-link" data-track="collector_to_converter_click" data-destination="comforting-hub">Explore the Comfort &amp; Rest hub</a>
      </div>
    </section>

    <section class="start-prompt">
      <p class="start-prompt-text">Not sure where to start?</p>
      <div class="start-prompt-links">
        <a href={ROUTES.coolingTop} class="start-prompt-link start-prompt-link--cool" data-track="collector_to_converter_click" data-destination="best-cooling-products">Our top cooling picks</a>
        <a href={ROUTES.calmingTop} class="start-prompt-link start-prompt-link--calm" data-track="collector_to_converter_click" data-destination="best-calming-products">Our top calming picks</a>
      </div>
    </section>

    <HomepageBody />
  </BaseLayout>
)}

<style>
  .comfort-block {
    background-color: #f0dfe0;
    padding: var(--space-3xl) var(--space-lg);
    text-align: center;
  }

  .comfort-block-inner {
    max-width: 640px;
    margin-inline: auto;
  }

  .comfort-tagline {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-rose);
    margin-bottom: var(--space-xs);
  }

  .comfort-heading {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
  }

  .comfort-description {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-lg);
  }

  .comfort-link {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    padding: var(--space-xs) var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-rose);
    color: var(--color-rose);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .comfort-link:hover {
    background: var(--color-rose);
    color: #fff;
  }

  .start-prompt {
    text-align: center;
    padding: var(--space-xl) var(--space-lg) var(--space-lg);
  }

  .start-prompt-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .start-prompt-links {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .start-prompt-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    padding: var(--space-xs) var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }

  .start-prompt-link--cool:hover {
    background: var(--color-sky);
    border-color: var(--color-sky);
    color: var(--color-charcoal);
  }

  .start-prompt-link--calm:hover {
    background: var(--color-sage);
    border-color: var(--color-sage);
    color: var(--color-charcoal);
  }
</style>
