---
import BaseLayout from '@layouts/BaseLayout.astro';
import Toc from '@components/modules/Toc.astro';
import CoolingProductCard from '@components/modules/CoolingProductCard.astro';
import FAQ from '@components/modules/FAQ.astro';
import InternalLinkStrip from '@components/modules/InternalLinkStrip.astro';
import Disclosure from '@components/modules/Disclosure.astro';
import JsonLd from '@components/JsonLd.astro';
import { getProductsByCategory } from '@data/cooling-products';
import { ROUTES } from '@data/routes';

const title = 'How to Keep a Dog Cool in a Car';
const description =
  'The back seat gets hotter than you think — even with AC running. Here\'s what actually works to keep your dog comfortable on any drive.';
const pageSlug = 'keep-dog-cool-in-car';

const carProducts = getProductsByCategory('car-cooling');

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: 'https://www.chill-dogs.com/cooling/keep-dog-cool-in-car/',
  image: ['https://www.chill-dogs.com/og/cooling-keep-dog-cool-in-car.png'],
  author: { '@type': 'Person', name: 'Benjamin Strawbridge', url: 'https://www.benstrawbridge.com/' },
  publisher: {
    '@type': 'Organization',
    name: 'Chill-Dogs',
    logo: { '@type': 'ImageObject', url: 'https://www.chill-dogs.com/og/og-default.png' },
  },
};

const tocHeadings = [
  { label: 'Why the back seat gets so hot', anchor: 'back-seat-heat' },
  { label: 'Quick fixes for every drive', anchor: 'quick-fixes' },
  { label: 'When to add a vest or bandana', anchor: 'vest-bandana' },
  { label: 'Planning longer drives', anchor: 'longer-drives' },
  { label: 'Signs your dog is overheating in the car', anchor: 'overheating-signs' },
];

const faqs = [
  {
    question: 'Is it safe to drive with my dog in the back seat with the AC on?',
    answer:
      'It can be, but AC vents typically point toward the front of the car. The back seat stays significantly warmer — often 10–15°F hotter — even when the cabin feels comfortable up front. Adding a clip-on fan or window shades helps close that gap.',
  },
  {
    question: 'What temperature is too hot for a dog in a car?',
    answer:
      'According to AKC, a car parked on a mild 60°F day can reach 100°F inside within minutes. For moving cars, the back seat can run well above ambient air temperature. If your dog is panting heavily and not settling, the temperature is likely too high.',
  },
  {
    question: 'Can I leave my dog in the car with the AC running?',
    answer:
      'Leaving any dog unattended in a running car carries risk — engines can stall, and AC can fail. For short stops, cracking windows and parking in shade is safer than relying on a running engine. Never leave a dog in a parked car on a hot day, even briefly.',
  },
  {
    question: 'How do I cool down a dog who is overheating in the car?',
    answer:
      'Pull over immediately and get your dog out of the car into shade. Offer cool (not ice cold) water to drink and apply tepid water to the paws, neck, and belly. Do not wrap in wet towels — AAHA notes this traps heat. Fan the dog and contact a vet as soon as possible.',
  },
  {
    question: 'Are some dogs at higher risk of overheating in the car?',
    answer:
      'Yes. Brachycephalic breeds (Bulldogs, Pugs, Boston Terriers, Boxers) have restricted airways and overheat faster. Overweight dogs, senior dogs, puppies, and dark or double-coated dogs are also at elevated risk. These dogs need extra airflow and shorter drive windows.',
  },
];

const internalLinks = [
  { label: 'Best Car Cooling Products', href: ROUTES.coolingCar },
  { label: 'Best Cooling Mats', href: ROUTES.coolingMats },
  { label: 'Best Cooling Bandanas', href: ROUTES.coolingBandanas },
  { label: 'Road Trip Chill Kit', href: ROUTES.roadTrip },
];
---

<BaseLayout title={title} description={description}>
  <JsonLd slot="head" schema={articleSchema} />
  <article class="collector-article container">
    <header class="article-header">
      <span class="eyebrow">Cooling &amp; Car Safety</span>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
    </header>

    <Toc headings={tocHeadings} pageSlug={pageSlug} />

    <div class="prose">

      <h2 id="back-seat-heat">Why the back seat gets so hot</h2>
      <p>
        Most car AC systems are designed around the front cabin. Vents point forward; cool air pools near the
        dashboard and front seats first. By the time conditioned air reaches the back, it has warmed considerably —
        creating a temperature gradient that can leave your dog's area 10–15°F hotter than where you're sitting.
      </p>
      <p>
        Sun angle compounds the problem. Rear side windows face directly into afternoon sun on most routes, and
        glass doesn't block infrared heat. Dark upholstery and vinyl seats absorb and radiate additional warmth.
        According to AKC, even a parked car on a mild 60°F day can reach 100°F inside within minutes — the physics
        of heat buildup work against your dog before you've even merged onto the highway.
      </p>
      <p>
        Dogs can't sweat like humans do. They regulate temperature primarily by panting — cycling air through
        their respiratory tract to evaporate moisture. In humid air or a poorly ventilated back seat, that
        process slows down. A dog that looks calm may already be working hard to stay cool.
      </p>

      <h2 id="quick-fixes">Quick fixes for every drive</h2>
      <p>
        The most effective car cooling setups combine three things: block incoming sun before it becomes heat,
        keep air moving in the back seat, and give your dog a cooler surface to rest on. Here are the practical
        tools that address each problem.
      </p>

      {carProducts.slice(0, 3).map((product, i) => (
        <div class="product-slot">
          <CoolingProductCard
            product={product}
            cta={{ label: 'See on Amazon', href: product.amazonUrl, kind: 'amazon' }}
            position={i + 1}
            pageType="collector"
            pageSlug={pageSlug}
          />
        </div>
      ))}

      <h2 id="vest-bandana">When to add a vest or bandana</h2>
      <p>
        Window shades and a fan handle the ambient temperature problem. But on longer drives or in stop-and-go
        traffic where AC cycling is less consistent, wearable cooling gear adds a layer of direct relief.
      </p>
      <p>
        A <a href={ROUTES.coolingBandanas} data-track="collector_to_converter_click" data-from-page={pageSlug} data-to-page={ROUTES.coolingBandanas} data-link-position="section"><strong>cooling bandana</strong></a> is the lightest option — soak it in water, wring it out, and tie it
        around your dog's neck before getting in the car. The evaporation cools the carotid artery area, which
        helps regulate overall body temperature. Good for drives under an hour in moderate heat.
      </p>
      <p>
        A <a href={ROUTES.coolingVests} data-track="collector_to_converter_click" data-from-page={pageSlug} data-to-page={ROUTES.coolingVests} data-link-position="section"><strong>cooling vest</strong></a> covers more surface area and lasts longer. Evaporative vests (soak, wring,
        wear) work well in drier climates; in high humidity, they're less effective since evaporation is slower.
        If your dog will be walking at rest stops or waiting outside in the sun, a vest is worth packing.
      </p>
      <p>
        At-risk dogs — brachycephalic breeds (Bulldogs, Pugs, Boxers, Boston Terriers), overweight dogs, and
        senior dogs — benefit most from wearable cooling since their natural temperature regulation is less
        efficient. For these dogs, layering wearable gear on top of good airflow is a practical precaution.
      </p>

      <h2 id="longer-drives">Planning longer drives</h2>
      <p>
        Longer drives introduce hydration as a factor. Dogs lose moisture through panting; in a warm back seat,
        that loss adds up quickly. Plan water stops every 1–2 hours, offer cool (not ice-cold) water, and carry
        more than you think you'll need. A collapsible, spill-proof bowl keeps the back seat dry and makes
        rest-stop hydration practical.
      </p>
      <p>
        Scheduling matters too. If you can choose your drive window, early morning or late evening routes avoid
        peak solar load — the back seat will stay meaningfully cooler. Midday summer driving on east-west routes
        (where sun hits the rear windows directly) is the hardest scenario for back-seat cooling.
      </p>
      <p>
        For multi-day road trips, the full gear setup — shades, fan, mat, vest, collapsible bowl — is worth
        the bag space. The <a href={ROUTES.roadTrip} data-track="collector_to_converter_click" data-from-page={pageSlug} data-to-page={ROUTES.roadTrip}>Road Trip Chill Kit guide</a> covers
        the complete checklist, including calming gear for dogs that get anxious on long drives.
      </p>

      {carProducts.slice(3).map((product, i) => (
        <div class="product-slot">
          <CoolingProductCard
            product={product}
            cta={{ label: 'See on Amazon', href: product.amazonUrl, kind: 'amazon' }}
            position={i + 4}
            pageType="collector"
            pageSlug={pageSlug}
          />
        </div>
      ))}

      <h2 id="overheating-signs">Signs your dog is overheating in the car</h2>
      <p>
        AAHA and AKC both document the progression of heat stress in dogs. Normal body temperature is 100–102.5°F;
        above 104°F is considered heatstroke territory, and dogs can reach that threshold faster than most owners
        expect. Watch for:
      </p>
      <ul>
        <li><strong>Heavy, rapid panting</strong> that doesn't slow down when the dog is at rest</li>
        <li><strong>Thick, ropey drool</strong> (AAHA notes this as an early warning sign)</li>
        <li><strong>Bright red gums</strong> or a very red tongue</li>
        <li><strong>Lethargy, incoordination, or confusion</strong> — difficulty standing or tracking movement</li>
        <li><strong>Vomiting or diarrhea</strong></li>
        <li><strong>Grayish or purple mouth</strong> — according to AKC, this is an emergency signal</li>
      </ul>
      <p>
        If you see multiple of these signs, pull over immediately. Get your dog out of the car and into shade.
        Apply tepid (not cold or icy) water to the paws, neck, and belly — AKC and AAHA both note that ice-cold
        water can constrict surface blood vessels and actually slow heat dissipation. Do not wrap in wet towels.
        Fan the dog with whatever is available and get to a vet as soon as possible, even if the dog seems to
        improve. Internal organ stress from overheating can develop after symptoms appear to resolve.
      </p>

    </div>

    <FAQ faqs={faqs} />

    <InternalLinkStrip links={internalLinks} fromPage={pageSlug} />

    <Disclosure />
  </article>
</BaseLayout>

<style>
  .collector-article {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-4xl);
    max-width: var(--max-width-prose);
  }

  .article-header {
    margin-bottom: var(--space-2xl);
  }

  .eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-text);
    margin-bottom: var(--space-sm);
  }

  .article-header h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
  }

  .lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .prose h2 {
    font-size: var(--text-2xl);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .prose p,
  .prose ul {
    margin-bottom: var(--space-md);
    line-height: 1.7;
  }

  .prose ul {
    padding-left: var(--space-lg);
  }

  .prose li {
    margin-bottom: var(--space-sm);
  }

  .prose a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .product-slot {
    margin: var(--space-xl) 0;
  }

  @media (max-width: 640px) {
    .article-header h1 {
      font-size: var(--text-3xl);
    }
  }
</style>
