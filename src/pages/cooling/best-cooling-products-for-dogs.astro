---
import BaseLayout from '@layouts/BaseLayout.astro';
import JsonLd from '@components/JsonLd.astro';
import Hero from '@components/modules/Hero.astro';
import SummaryBlock from '@components/modules/SummaryBlock.astro';
import Toc from '@components/modules/Toc.astro';
import CoolingProductCard from '@components/modules/CoolingProductCard.astro';
import BonusCallout from '@components/modules/BonusCallout.astro';
import FAQ from '@components/modules/FAQ.astro';
import Disclosure from '@components/modules/Disclosure.astro';
import RelatedGuides from '@components/modules/RelatedGuides.astro';
import InternalLinkStrip from '@components/modules/InternalLinkStrip.astro';
import { getProductsByCategory, getBonusProduct } from '@data/cooling-products';

const pageSlug = 'best-cooling-products-for-dogs';

const mats = getProductsByCategory('cooling-mats');
const bandanas = getProductsByCategory('cooling-bandanas');
const vests = getProductsByCategory('cooling-vests');
const toys = getProductsByCategory('freezable-dog-toys');
const bonus = getBonusProduct();

const summaryItems = [
  {
    label: 'Cooling Mats',
    href: '/cooling/cooling-mats/',
    picks: ['The Green Pet Shop Cooling Pad — best gel mat', 'K&H Cool Bed III — best for large breeds'],
  },
  {
    label: 'Cooling Bandanas',
    href: '/cooling/cooling-bandanas/',
    picks: ['AFP Chill Out Ice Bandana — ice-pack option', 'KYEESE 2-Pack — great value'],
  },
  {
    label: 'Cooling Vests',
    href: '/cooling/cooling-vests/',
    picks: ['Ruffwear Swamp Cooler — best for hiking', 'Kurgo Core — budget-friendly'],
  },
  {
    label: 'Freezable Toys',
    href: '/cooling/freezable-dog-toys/',
    picks: ['KONG Classic — freeze-and-stuff legend', 'PetSafe Chilly Penguin — cool hydration'],
  },
];

const tocHeadings = [
  { label: 'Best Cooling Mats', anchor: 'cooling-mats' },
  { label: 'Best Cooling Bandanas', anchor: 'cooling-bandanas' },
  { label: 'Best Cooling Vests', anchor: 'cooling-vests' },
  { label: 'Best Freezable Toys', anchor: 'freezable-toys' },
  { label: 'Bonus: NASA-Inspired Bed', anchor: 'bonus' },
  { label: 'FAQ', anchor: 'faq' },
];

const allProducts = [...mats, ...bandanas, ...vests, ...toys, ...(bonus ? [bonus] : [])];
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '10 Best Cooling Products for Dogs (2026)',
  url: 'https://chill-dogs.com/cooling/best-cooling-products-for-dogs/',
  numberOfItems: allProducts.length,
  itemListElement: allProducts.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.name,
    url: p.amazonUrl,
  })),
};

const pillarFaqs = [
  {
    question: 'How do I know if my dog is overheating?',
    answer:
      "Watch for excessive panting, drooling, bright red gums, vomiting, or staggering. If you see these signs, move your dog to shade, offer cool (not ice-cold) water, and seek professional help immediately.",
  },
  {
    question: 'Are cooling mats safe for dogs who chew?',
    answer:
      'The gel in pressure-activated mats is generally non-toxic, but heavy chewers should be supervised. Water-based mats like the K&H Cool Bed III are a better choice for destructive dogs since they contain only water.',
  },
  {
    question: 'Do cooling vests lower body temperature?',
    answer:
      'Yes — evaporative vests can reduce surface temperature by several degrees. They work best in dry climates with airflow. In high humidity, cooling effect is reduced.',
  },
  {
    question: 'At what temperature is it too hot to walk my dog?',
    answer:
      "If pavement is too hot for your hand (hold it flat for 7 seconds), it's too hot for paws. Generally, limit walks when air temperature exceeds 85 °F (29 °C), and walk during early morning or evening.",
  },
  {
    question: 'Can dogs overheat indoors?',
    answer:
      'Absolutely. Homes without air conditioning can reach dangerous temperatures on hot days. A cooling mat indoors gives your dog a self-serve cool-down spot. Keep water available and consider a fan.',
  },
];
---

<BaseLayout
  title="10 Best Cooling Products for Dogs (2026)"
  description="Beat the heat with our expert picks: cooling mats, bandanas, vests, and freezable toys compared for comfort, durability, and practicality. Keep your dog safe and comfortable all summer."
>
  <JsonLd slot="head" schema={itemListSchema} />


  <Hero
    title="The 10 Best Cooling Products for Dogs in 2026"
    subtitle="Summer heat is no joke for dogs. We researched and compared the top cooling mats, bandanas, vests, and toys so you can pick the right gear for your pup."
    disclaimer="As an Amazon Associate, we earn from qualifying purchases."
    primaryCta={{ label: 'See Best Cooling Mats', href: '/cooling/cooling-mats/' }}
    pageSlug={pageSlug}
  />

  <div class="pillar-content">
    <SummaryBlock items={summaryItems} />

    <Toc headings={tocHeadings} pageSlug={pageSlug} />

    <!-- Cooling Mats -->
    <section class="pillar-section" id="cooling-mats">
      <div class="section-inner">
        <h2>Best Cooling Mats for Dogs</h2>
        <p class="section-intro">
          A cooling mat gives your dog an instant cool spot — no prep, no electricity. Great for crates, beds, or just the kitchen floor.
        </p>
        <div class="section-grid section-grid--3">
          {mats.map((product, i) => (
            <CoolingProductCard
              product={product}
              cta={{ label: 'See best cooling mats', href: '/cooling/cooling-mats/', kind: 'internal' }}
              position={i + 1}
              pageType="collector"
              pageSlug={pageSlug}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Cooling Bandanas -->
    <section class="pillar-section" id="cooling-bandanas">
      <div class="section-inner">
        <h2>Best Cooling Bandanas for Dogs</h2>
        <p class="section-intro">
          The simplest cooling hack: soak, wring, tie. Bandanas are lightweight, packable, and work in minutes.
        </p>
        <div class="section-grid section-grid--2">
          {bandanas.map((product, i) => (
            <CoolingProductCard
              product={product}
              cta={{ label: 'See best cooling bandanas', href: '/cooling/cooling-bandanas/', kind: 'internal' }}
              position={i + 1}
              pageType="collector"
              pageSlug={pageSlug}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Cooling Vests -->
    <section class="pillar-section" id="cooling-vests">
      <div class="section-inner">
        <h2>Best Cooling Vests for Dogs</h2>
        <p class="section-intro">
          For hikes, runs, and extended outdoor time, a cooling vest is the most effective wearable option. Soak it and go.
        </p>
        <div class="section-grid section-grid--3">
          {vests.map((product, i) => (
            <CoolingProductCard
              product={product}
              cta={{ label: 'See best cooling vests', href: '/cooling/cooling-vests/', kind: 'internal' }}
              position={i + 1}
              pageType="collector"
              pageSlug={pageSlug}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Freezable Toys -->
    <section class="pillar-section" id="freezable-toys">
      <div class="section-inner">
        <h2>Best Freezable Dog Toys</h2>
        <p class="section-intro">
          Stuff, freeze, and let your dog work for a cold treat. Freezable toys combine enrichment with cooling relief.
        </p>
        <div class="section-grid section-grid--2">
          {toys.map((product, i) => (
            <CoolingProductCard
              product={product}
              cta={{ label: 'See best freezable toys', href: '/cooling/freezable-dog-toys/', kind: 'internal' }}
              position={i + 1}
              pageType="collector"
              pageSlug={pageSlug}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Bonus -->
    <section id="bonus">
      {bonus && <BonusCallout product={bonus} pageSlug={pageSlug} />}
    </section>

    <!-- FAQ -->
    <section id="faq">
      <FAQ faqs={pillarFaqs} heading="Cooling & Heat Safety FAQ" />
    </section>

    <RelatedGuides
      heading="Beyond the Heat"
      guides={[
        {
          href: '/travel/rhys-road-trip-chill-kit/',
          title: "Rhys's Road Trip Chill Kit",
          description: 'Planning a long drive? See the complete road trip cooling and calming setup — window shades, fans, mats, and anxiety picks built from a real cross-country trip.',
        },
        {
          href: '/calming/best-calming-products-for-anxious-dogs/',
          title: 'Best Calming Products for Anxious Dogs',
          description: 'Hot dogs are often anxious dogs. If your pup gets restless during summer storms or fireworks, our calming guide covers wraps, treats, and enrichment tools.',
        },
        {
          href: '/calming/best-thundershirt-alternatives/',
          title: 'Best ThunderShirt Alternatives',
          description: 'ThunderShirt not the right fit? Compare calming chews, lick mats, and snuffle mats as practical alternatives.',
        },
      ]}
    />

    <Disclosure />

    <InternalLinkStrip
      links={[
        { label: 'Back to Cooling Hub', href: '/cooling/' },
        { label: 'Cooling Mats', href: '/cooling/cooling-mats/' },
        { label: 'Cooling Bandanas', href: '/cooling/cooling-bandanas/' },
        { label: 'Cooling Vests', href: '/cooling/cooling-vests/' },
        { label: 'Freezable Toys', href: '/cooling/freezable-dog-toys/' },
      ]}
      fromPage={pageSlug}
    />
  </div>
</BaseLayout>

<style>
  .pillar-content {
    padding-bottom: var(--space-2xl);
  }

  .pillar-section {
    padding: var(--space-2xl) var(--space-lg);
  }

  .pillar-section:nth-child(even) {
    background: var(--color-bg-alt);
  }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-inner h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-sm);
  }

  .section-intro {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-xl);
    max-width: var(--max-width-prose);
  }

  .section-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .section-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .section-grid--2 {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (max-width: 1024px) {
    .section-grid--3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .section-grid--3,
    .section-grid--2 {
      grid-template-columns: 1fr;
    }

    .pillar-section {
      padding: var(--space-xl) var(--space-md);
    }
  }
</style>
