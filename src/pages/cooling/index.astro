---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroExperiment from '@components/modules/HeroExperiment.astro';
import CoolingHubBody from '@components/modules/CoolingHubBody.astro';
import JsonLd from '@components/JsonLd.astro';

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Cooling Relief for Dogs',
  url: 'https://www.chill-dogs.com/cooling/',
  description: 'Beat the heat with our curated cooling picks for dogs — from cooling mats and vests to frozen treats and shade solutions.',
  hasPart: [
    { '@type': 'WebPage', name: 'Best Cooling Products for Dogs', url: 'https://www.chill-dogs.com/cooling/best-cooling-products-for-dogs/' },
    { '@type': 'WebPage', name: 'Best Cooling Mats', url: 'https://www.chill-dogs.com/cooling/cooling-mats/' },
    { '@type': 'WebPage', name: 'Best Cooling Bandanas', url: 'https://www.chill-dogs.com/cooling/cooling-bandanas/' },
    { '@type': 'WebPage', name: 'Best Cooling Vests', url: 'https://www.chill-dogs.com/cooling/cooling-vests/' },
    { '@type': 'WebPage', name: 'Best Freezable Dog Toys', url: 'https://www.chill-dogs.com/cooling/freezable-dog-toys/' },
    { '@type': 'WebPage', name: 'How Hot Is Too Hot for Dogs?', url: 'https://www.chill-dogs.com/cooling/how-hot-is-too-hot-for-dogs/' },
  ],
};
---

<BaseLayout
  title="Cooling Relief"
  description="Beat the heat with our curated cooling picks for dogs — from cooling mats and vests to frozen treats and shade solutions."
>
  <JsonLd slot="head" schema={collectionSchema} />
  <HeroExperiment
    variant="c"
    theme="cooling"
    headline="Beat the Heat in Minutes"
    subhead="Cooling and hydration products that work"
    primaryCta={{ label: 'See top cooling picks', href: '/cooling/best-cooling-products-for-dogs/' }}
    secondaryCta={{ label: 'How we choose products', href: '/about/#how-we-choose' }}
  />

  <CoolingHubBody />
</BaseLayout>
