---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/modules/Hero.astro';
import Disclosure from '@components/modules/Disclosure.astro';
---

<BaseLayout
  title="Cooling Relief"
  description="Beat the heat with our curated cooling picks for dogs — from cooling mats and vests to frozen treats and shade solutions."
>
  <script slot="head" type="module">
    import { init } from '/src/scripts/analytics.ts';
    init();
  </script>

  <Hero
    title="Keep Your Dog Cool This Summer"
    subtitle="Dogs overheat fast. We test and compare the best cooling mats, vests, bandanas, and toys so you can pick the right gear — and skip the junk."
    primaryCta={{ label: 'Read the Full Guide', href: '/cooling/best-cooling-products-for-dogs/' }}
  />

  <!-- Start Here callout -->
  <section class="start-here">
    <div class="start-here-inner">
      <span class="start-here-label">Start here</span>
      <h2>
        <a
          href="/cooling/best-cooling-products-for-dogs/"
          data-track="collector_to_converter_click"
          data-from-page="cooling-hub"
          data-to-page="/cooling/best-cooling-products-for-dogs/"
          data-link-position="hero"
        >
          10 Best Cooling Products for Dogs (2026)
        </a>
      </h2>
      <p>Our complete guide covering mats, bandanas, vests, and toys — with quick picks, comparisons, and heat safety tips.</p>
    </div>
  </section>

  <!-- Category Grid -->
  <section class="categories">
    <h2 class="categories-heading">Shop by Category</h2>
    <div class="categories-grid">
      <a
        href="/cooling/cooling-mats/"
        class="cat-card"
        data-track="collector_to_converter_click"
        data-from-page="cooling-hub"
        data-to-page="/cooling/cooling-mats/"
        data-category="cooling-mats"
        data-link-position="section"
      >
        <h3>Cooling Mats</h3>
        <p>Pressure-activated and water-based mats for instant relief at home or on the go.</p>
        <span class="cat-card-link">See our picks &rarr;</span>
      </a>
      <a
        href="/cooling/cooling-bandanas/"
        class="cat-card"
        data-track="collector_to_converter_click"
        data-from-page="cooling-hub"
        data-to-page="/cooling/cooling-bandanas/"
        data-category="cooling-bandanas"
        data-link-position="section"
      >
        <h3>Cooling Bandanas</h3>
        <p>Lightweight, soak-and-go cooling for daily walks in the heat.</p>
        <span class="cat-card-link">See our picks &rarr;</span>
      </a>
      <a
        href="/cooling/cooling-vests/"
        class="cat-card"
        data-track="collector_to_converter_click"
        data-from-page="cooling-hub"
        data-to-page="/cooling/cooling-vests/"
        data-category="cooling-vests"
        data-link-position="section"
      >
        <h3>Cooling Vests</h3>
        <p>Evaporative vests for hikes, runs, and extended outdoor time.</p>
        <span class="cat-card-link">See our picks &rarr;</span>
      </a>
      <a
        href="/cooling/freezable-dog-toys/"
        class="cat-card"
        data-track="collector_to_converter_click"
        data-from-page="cooling-hub"
        data-to-page="/cooling/freezable-dog-toys/"
        data-category="freezable-dog-toys"
        data-link-position="section"
      >
        <h3>Freezable Toys</h3>
        <p>Stuff, freeze, and let your dog work for a cold treat.</p>
        <span class="cat-card-link">See our picks &rarr;</span>
      </a>
    </div>
  </section>

  <Disclosure />
</BaseLayout>

<style>
  /* Start Here */
  .start-here {
    max-width: var(--max-width-prose);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) 0;
  }

  .start-here-inner {
    background: var(--color-surface);
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
  }

  .start-here-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .start-here-inner h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
  }

  .start-here-inner h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .start-here-inner h2 a:hover {
    color: var(--color-primary);
  }

  .start-here-inner p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* Categories */
  .categories {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) var(--space-xl);
  }

  .categories-heading {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .cat-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow var(--transition-base);
    display: flex;
    flex-direction: column;
  }

  .cat-card:hover {
    box-shadow: var(--shadow-md);
  }

  .cat-card h3 {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-sm);
  }

  .cat-card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    flex: 1;
    margin-bottom: var(--space-md);
  }

  .cat-card-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
  }

  .cat-card:hover .cat-card-link {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
