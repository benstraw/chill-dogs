---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroExperiment from '@components/modules/HeroExperiment.astro';
import RelaxationHubBody from '@components/modules/RelaxationHubBody.astro';
import JsonLd from '@components/JsonLd.astro';

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Comfort & Rest for Dogs',
  url: 'https://www.chill-dogs.com/comforting/',
  description: 'Calming beds, orthopedic beds, chew-resistant beds, travel beds, and rest gear for dogs who need more than a mat on the floor.',
  hasPart: [
    { '@type': 'WebPage', name: 'Best Calming Dog Beds', url: 'https://www.chill-dogs.com/comforting/best-calming-dog-beds/' },
    { '@type': 'WebPage', name: 'Best Orthopedic Dog Beds', url: 'https://www.chill-dogs.com/comforting/best-orthopedic-dog-beds/' },
    { '@type': 'WebPage', name: 'Best Chew-Resistant Dog Beds', url: 'https://www.chill-dogs.com/comforting/best-chew-resistant-dog-beds/' },
    { '@type': 'WebPage', name: 'Best Dog Travel Beds', url: 'https://www.chill-dogs.com/comforting/best-dog-travel-beds/' },
  ],
};
---

<BaseLayout
  title="Comfort & Rest"
  ogTitle="Dog Beds for Comfort & Rest | Calming & Orthopedic Picks"
  description="Calming beds, orthopedic beds, chew-resistant beds, travel beds, and rest gear for dogs who need more than a mat on the floor."
>
  <JsonLd slot="head" schema={collectionSchema} />
  <HeroExperiment
    variant="c"
    theme="comfort"
    headline="Rest. Recovery. Relaxation."
    subhead="Beds and rest gear for dogs who sleep hard and deserve the right support"
    primaryCta={{ label: 'See calming beds', href: '/comforting/best-calming-dog-beds/' }}
    secondaryCta={{ label: 'Orthopedic beds', href: '/comforting/best-orthopedic-dog-beds/' }}
  />

  <RelaxationHubBody />
</BaseLayout>
