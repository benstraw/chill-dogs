        "texts": [
          {
            "position": 1,
            "title": "8-Inch Raised Comfort Bolster Headrest",
            "text": "Gives large and giant breeds a natural place to rest their head. Supports neck and spine alignment and maintains its height and shape over time — even under the weight of 100+ pound dogs."
          },
          {
            "position": 2,
            "title": "Removable Plush Cover",
            "text": "Polyester fabric that unzips completely for easy machine washing. Gentle cycle, cold water, tumble dry low. Washes up like new every time."
          },
          {
            "position": 3,
            "title": "Non-Slip Rubber Base",
            "text": "Keeps the bed locked in place on hardwood, tile, or inside your 54-inch crate. No sliding, no bunching, no readjusting."
          },
          {
            "position": 4,
            "title": "Separate Waterproof Liner with Zipper",
            "text": "Dedicated waterproof liner completely wraps the foam core so spills, drool, and accidents reach the most expensive part of the bed. This is a separate layer, not spray-on waterproofing that wears off."
          },
          {
            "position": 5,
            "title": "5.5\" Ultra High-Density 45D Orthopedic Foam",
            "text": "The same performance-grade foam density used in premium human mattresses. Supports more weight with less bulk and resists flattening for years, not months. Backed by our 10-year foam core commitment."
          }
        ]
      }
