---
interface Props {
  headline: string;
  subheadline: string;
  ctaCooling: { text: string; href: string };
  ctaCalming: { text: string; href: string };
  microcopy?: string;
}

const {
  headline,
  subheadline,
  ctaCooling,
  ctaCalming,
  microcopy = 'Curated picks. Affiliate-supported. No fluff.',
} = Astro.props;
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <h1 class="hero-headline">{headline}</h1>
      <p class="hero-sub">{subheadline}</p>

      <div class="hero-ctas">
        <a
          href={ctaCooling.href}
          class="hero-cta cta-cooling"
          data-track="hero_click_cooling"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="12" y1="2" x2="12" y2="22" />
            <path d="M20 16l-4-4 4-4" />
            <path d="M4 16l4-4-4-4" />
            <line x1="2" y1="12" x2="22" y2="12" />
            <path d="M16 20l-4 4-4-4" />
            <path d="M16 4l-4-4-4 4" />
          </svg>
          {ctaCooling.text}
        </a>
        <a
          href={ctaCalming.href}
          class="hero-cta cta-calming"
          data-track="hero_click_calming"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
          </svg>
          {ctaCalming.text}
        </a>
      </div>

      <p class="hero-microcopy">{microcopy}</p>

      <div class="hero-trust">
        <div class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
          </svg>
          <span>Research-backed picks</span>
        </div>
        <div class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
          </svg>
          <span>Fast-shipping favorites</span>
        </div>
        <div class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
          <span>Trusted by dog owners</span>
        </div>
      </div>

      <p class="hero-compliance">
        As an Amazon Associate we earn from qualifying purchases.
      </p>
    </div>

    <div class="hero-visual">
      <div class="hero-image-frame">
        <img
          src="/images/hero-dog.png"
          alt="A happy golden retriever lounging on a cooling mat in a modern living room with a calming blanket nearby"
          width="1920"
          height="1080"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-track]').forEach((el) => {
    el.addEventListener('click', () => {
      const action = el.getAttribute('data-track');
      if (typeof gtag === 'function') {
        gtag('event', action, {
          event_category: 'hero',
          event_label: action,
          transport_type: 'beacon',
        });
      }
    });
  });
</script>

<style>
  .hero {
    background: var(--color-bg-cool);
    padding: var(--space-4xl) 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-headline {
    font-size: var(--text-5xl);
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-lg);
  }

  .hero-sub {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-xl);
    max-width: 480px;
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .hero-cta {
    flex: 1 1 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .cta-cooling {
    background: var(--color-sky);
    color: var(--color-charcoal);
  }

  .cta-cooling:hover {
    background: var(--color-sky-hover);
    color: var(--color-charcoal);
  }

  .cta-calming {
    background: var(--color-sage);
    color: var(--color-charcoal);
  }

  .cta-calming:hover {
    background: var(--color-sage-hover);
    color: var(--color-charcoal);
  }

  .hero-microcopy {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .trust-item svg {
    color: var(--color-sky);
    flex-shrink: 0;
  }

  .hero-compliance {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Visual / Image column */
  .hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-image-frame {
    width: 100%;
    max-width: 560px;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .hero-image-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ─── Responsive ─── */
  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-sub {
      margin-inline: auto;
    }

    .hero-ctas {
      justify-content: center;
    }

    .hero-microcopy {
      text-align: center;
    }

    .hero-trust {
      justify-content: center;
    }

    .hero-compliance {
      text-align: center;
    }

    .hero-visual {
      order: 1;
    }

    .hero-copy {
      order: 0;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-3xl) 0;
    }

    .hero-headline {
      font-size: var(--text-3xl);
    }

    .hero-ctas {
      flex-direction: column;
    }

    .hero-cta {
      flex: none;
    }
  }
</style>
