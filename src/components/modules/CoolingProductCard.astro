---
import AffiliateLink from '@components/AffiliateLink.astro';
import type { CoolingProduct } from '@data/cooling-products';

interface Props {
  product: CoolingProduct;
  cta: { label: string; href: string; kind: 'internal' | 'amazon' };
  position?: number;
  pageType?: 'collector' | 'converter';
  pageSlug?: string;
}

const { product, cta, position = 0, pageType = 'converter', pageSlug = '' } = Astro.props;

const isAmazon = cta.kind === 'amazon';
const trackEvent = isAmazon ? 'amazon_outbound_click' : 'collector_to_converter_click';
---

<div class="cp-card">
  {product.rhysApproved && (
    <div class="cp-rhys-badge">Rhys Approved Product</div>
  )}
  <div class="cp-image">
    {product.image ? (
      <img
        src={product.image.src}
        alt={product.image.alt}
        width="400"
        height="300"
        loading="lazy"
        decoding="async"
        onerror="this.style.display='none';this.parentElement.classList.add('cp-image--fallback')"
      />
    ) : (
      <div class="cp-image-placeholder" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="48" height="48" fill="currentColor" aria-hidden="true">
          <path d="M50 15c-5.5 0-10 4.5-10 10s4.5 10 10 10 10-4.5 10-10-4.5-10-10-10zm-20 25c-3.3 0-6 2.7-6 6v4c0 8.8 11.2 16 26 16s26-7.2 26-16v-4c0-3.3-2.7-6-6-6H30zm-8 30c-2.2 0-4 1.8-4 4s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4zm56 0c-2.2 0-4 1.8-4 4s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4zM36 78c-2.2 0-4 1.8-4 4s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4zm28 0c-2.2 0-4 1.8-4 4s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4z"/>
        </svg>
      </div>
    )}
  </div>
  <div class="cp-body">
    <h3 class="cp-name">{product.name}</h3>
    <p class="cp-best-for">
      <strong>Best for:</strong> {product.bestFor}
    </p>
    <ul class="cp-bullets">
      {product.bullets.map((b) => <li>{b}</li>)}
    </ul>
    {product.coolingMethod && (
      <p class="cp-meta">
        <span class="cp-meta-label">Cooling:</span> {product.coolingMethod}
      </p>
    )}
    {product.sizingNote && (
      <p class="cp-meta">
        <span class="cp-meta-label">Sizing:</span> {product.sizingNote}
      </p>
    )}
    {isAmazon ? (
      <AffiliateLink
        href={cta.href}
        class="cp-cta"
        data-track={trackEvent}
        data-page-type={pageType}
        data-page-slug={pageSlug}
        data-product-name={product.name}
        data-product-category={product.category}
        data-position={String(position)}
        data-destination="amazon.com"
      >
        {cta.label}
      </AffiliateLink>
    ) : (
      <a
        href={cta.href}
        class="cp-cta"
        data-track={trackEvent}
        data-from-page={pageSlug}
        data-to-page={cta.href}
        data-category={product.category}
        data-link-position="section"
      >
        {cta.label}
      </a>
    )}
  </div>
</div>

<style>
  .cp-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    transition: box-shadow var(--transition-base);
    position: relative;
  }

  .cp-rhys-badge {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-terracotta, #b85c38);
    background: color-mix(in srgb, var(--color-terracotta, #b85c38) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-terracotta, #b85c38) 30%, transparent);
    padding: 3px var(--space-sm);
    border-radius: var(--radius-full, 999px);
    z-index: 1;
  }

  .cp-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .cp-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .cp-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #fff;
  }

  .cp-image--fallback,
  .cp-image:has(.cp-image-placeholder) {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cp-image-placeholder {
    color: var(--color-sage);
    opacity: 0.5;
  }

  .cp-body {
    padding: var(--space-lg);
  }

  .cp-name {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-sm);
  }

  .cp-best-for {
    font-size: var(--text-sm);
    color: var(--color-accent-text);
    margin-bottom: var(--space-md);
    line-height: var(--leading-normal);
  }

  .cp-best-for strong {
    color: var(--color-text);
  }

  .cp-bullets {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
    line-height: var(--leading-normal);
  }

  .cp-bullets li {
    padding-left: var(--space-md);
    position: relative;
    margin-bottom: var(--space-xs);
  }

  .cp-bullets li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-accent-text);
    font-weight: var(--weight-bold);
  }

  .cp-meta {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .cp-meta-label {
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  :global(.cp-cta) {
    display: block;
    text-align: center;
    background: var(--color-primary);
    color: var(--color-text-inverse) !important;
    font-weight: var(--weight-semibold);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
    text-decoration: none;
  }

  :global(.cp-cta:hover) {
    background: var(--color-primary-hover);
    color: var(--color-text-inverse) !important;
  }

  :global(.cp-cta:focus-visible) {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>
