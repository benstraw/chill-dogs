---
import AffiliateLink from '@components/AffiliateLink.astro';
import type { CoolingProduct } from '@data/cooling-products';

interface Props {
  product: CoolingProduct;
  pageSlug?: string;
}

const { product, pageSlug = '' } = Astro.props;
---

<aside class="bonus" aria-label="Bonus pick">
  <div class="bonus-inner">
    <span class="bonus-badge">Bonus Pick</span>
    <h3 class="bonus-name">{product.name}</h3>
    <p class="bonus-best-for">
      <strong>Best for:</strong> {product.bestFor}
    </p>
    <ul class="bonus-bullets">
      {product.bullets.map((b) => <li>{b}</li>)}
    </ul>
    <AffiliateLink
      href={product.amazonUrl}
      class="bonus-cta"
      data-track="amazon_outbound_click"
      data-page-type="collector"
      data-page-slug={pageSlug}
      data-product-name={product.name}
      data-product-category="bonus"
      data-position="11"
      data-destination="amazon.com"
    >
      Check Price on Amazon
    </AffiliateLink>
  </div>
</aside>

<style>
  .bonus {
    max-width: var(--max-width-prose);
    margin: var(--space-2xl) auto;
    padding: 0 var(--space-lg);
  }

  .bonus-inner {
    background: linear-gradient(135deg, var(--color-bg-cool), var(--color-surface));
    border: 2px solid var(--color-primary);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    position: relative;
  }

  .bonus-badge {
    display: inline-block;
    background: var(--color-accent-alt);
    color: var(--color-text-inverse);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-md);
  }

  .bonus-name {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-sm);
  }

  .bonus-best-for {
    font-size: var(--text-sm);
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .bonus-best-for strong {
    color: var(--color-text);
  }

  .bonus-bullets {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    line-height: var(--leading-normal);
  }

  .bonus-bullets li {
    padding-left: var(--space-md);
    position: relative;
    margin-bottom: var(--space-xs);
  }

  .bonus-bullets li::before {
    content: '\2605';
    position: absolute;
    left: 0;
    color: var(--color-accent-alt);
  }

  :global(.bonus-cta) {
    display: inline-block;
    background: var(--color-accent-alt);
    color: var(--color-text-inverse) !important;
    font-weight: var(--weight-semibold);
    padding: var(--space-sm) var(--space-xl);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  :global(.bonus-cta:hover) {
    opacity: 0.9;
    color: var(--color-text-inverse) !important;
  }
</style>
