---
interface SummaryItem {
  label: string;
  href: string;
  picks: string[];
  image?: { src: string; alt: string };
}

interface Props {
  heading?: string;
  items: SummaryItem[];
}

const { heading = 'Quick Picks by Category', items } = Astro.props;
---

<section class="summary" aria-label="Quick picks summary">
  <h2 class="summary-heading">{heading}</h2>
  <div class="summary-grid">
    {items.map((item) => (
      <div class="summary-card">
        {item.image && (
          <div class="summary-card-image">
            <img
              src={item.image.src}
              alt={item.image.alt}
              loading="lazy"
              decoding="async"
              width="240"
              height="180"
              onerror="this.style.display='none'"
            />
          </div>
        )}
        <div class="summary-card-body">
          <h3 class="summary-card-title">
            <a
              href={item.href}
              data-track="collector_to_converter_click"
              data-to-page={item.href}
              data-link-position="summary"
            >
              {item.label}
            </a>
          </h3>
          <ul class="summary-picks">
            {item.picks.map((pick) => (
              <li>{pick}</li>
            ))}
          </ul>
          <a
            href={item.href}
            class="summary-cta"
            data-track="collector_to_converter_click"
            data-to-page={item.href}
            data-link-position="summary"
          >
            See our picks &rarr;
          </a>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .summary {
    padding: var(--space-2xl) var(--space-lg);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .summary-heading {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-lg);
  }

  .summary-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .summary-card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .summary-card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: #fff;
  }

  .summary-card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .summary-card-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-sm);
  }

  .summary-card-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .summary-card-title a:hover {
    color: var(--color-primary);
  }

  .summary-picks {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
    flex: 1;
  }

  .summary-picks li {
    padding-left: var(--space-md);
    position: relative;
    margin-bottom: var(--space-xs);
  }

  .summary-picks li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: var(--weight-bold);
  }

  .summary-cta {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    text-decoration: none;
  }

  .summary-cta:hover {
    text-decoration: underline;
  }
</style>
