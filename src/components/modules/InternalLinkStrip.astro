---
interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  heading?: string;
  links: LinkItem[];
  fromPage?: string;
}

const { heading = 'More Cooling Guides', links, fromPage = '' } = Astro.props;
---

<nav class="ils" aria-label="Related guides">
  <h2 class="ils-heading">{heading}</h2>
  <ul class="ils-list">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class="ils-link"
          data-track="collector_to_converter_click"
          data-from-page={fromPage}
          data-to-page={link.href}
          data-link-position="footer"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .ils {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg);
    text-align: center;
  }

  .ils-heading {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-lg);
  }

  .ils-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ils-link {
    display: inline-block;
    background: var(--color-bg-alt);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .ils-link:hover {
    background: var(--color-primary);
    color: var(--color-text-inverse);
  }

  .ils-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>
