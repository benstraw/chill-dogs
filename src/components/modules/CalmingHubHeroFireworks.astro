      <line x1="0" y1="0" x2="0"    y2="-52" stroke="#ffd166" stroke-width="2.2" stroke-linecap="round" opacity="0.9"/>
      <line x1="0" y1="0" x2="37"   y2="-37" stroke="#ffd166" stroke-width="2"   stroke-linecap="round" opacity="0.85"/>
