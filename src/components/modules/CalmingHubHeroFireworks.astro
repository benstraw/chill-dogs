    <circle cx="210" cy="22"  r="0.9" fill="#fff" opacity="0.55"/>
    <circle cx="340" cy="65"  r="1.4" fill="#fff" opacity="0.8"/>
    <circle cx="490" cy="30"  r="1"   fill="#fff" opacity="0.6"/>
    <circle cx="620" cy="18"  r="0.8" fill="#fff" opacity="0.5"/>
    <circle cx="760" cy="52"  r="1.3" fill="#fff" opacity="0.75"/>
    <circle cx="900" cy="28"  r="1"   fill="#fff" opacity="0.65"/>
    <circle cx="1050" cy="44" r="1.5" fill="#fff" opacity="0.8"/>
