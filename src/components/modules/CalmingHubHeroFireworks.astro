<style>
  @import url('https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Fredoka:wght@400;600&display=swap');

  /* ── Color palette ── */
  .fw-hero {
    --fw-midnight:  #040c18;
    --fw-navy:      #080f1e;
    --fw-deep:      #0b1628;
    --fw-gold:      #ffd166;
    --fw-gold-pale: #fff7cc;
    --fw-pink:      #ff6ec7;
    --fw-pink-pale: #ffcce8;
    --fw-teal:      #4de8c4;
    --fw-teal-pale: #ccfaf2;
    --fw-violet:    #b388ff;
    --fw-violet-pale: #ede0ff;
    --fw-red:       #ff5252;
    --fw-lime:      #b2ff59;
    --fw-ice:       #a8daec;
    --fw-powder:    #d6eef8;
    --fw-dog-tan:   #d4956a;
    --fw-dog-dark:  #a06830;
    --fw-calm-glow: rgba(77, 232, 196, 0.22);
  }

  /* ── Section base ── */
  .fw-hero {
    position: relative;
    overflow: hidden;
    min-height: 520px;
    background: linear-gradient(
      180deg,
      #010510 0%,
      #040c18 25%,
      #050e1c 55%,
      #07101f 100%
    );
    font-family: 'Fredoka', var(--font-body, sans-serif);
    padding: 5rem 1.5rem 7rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Sky SVG ── */
  .fw-sky-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Firework burst animations ── */
  .fw-burst {
    transform-origin: center;
    animation: fw-pop 3s ease-out infinite;
  }

  .fw-burst--1 { animation-delay: 0s;    animation-duration: 3.2s; }
  .fw-burst--2 { animation-delay: -1.1s; animation-duration: 2.9s; }
  .fw-burst--3 { animation-delay: -0.55s; animation-duration: 3.5s; }
  .fw-burst--4 { animation-delay: -2s;   animation-duration: 3.1s; }
  .fw-burst--5 { animation-delay: -1.6s; animation-duration: 2.8s; }
  .fw-burst--6 { animation-delay: -0.8s; animation-duration: 3.4s; }
  .fw-burst--7 { animation-delay: -0.3s; animation-duration: 3.0s; }
  .fw-burst--8 { animation-delay: -2.4s; animation-duration: 3.3s; }
  .fw-burst--9 { animation-delay: -1.8s; animation-duration: 2.7s; }
  .fw-burst--10 { animation-delay: -0.9s; animation-duration: 3.6s; }

  @keyframes fw-pop {
    0%   { opacity: 0;   transform: scale(0.1); }
    12%  { opacity: 1;   transform: scale(1.1); }
    30%  { opacity: 0.9; transform: scale(1); }
    65%  { opacity: 0.5; transform: scale(1.02); }
    100% { opacity: 0;   transform: scale(1.15); }
  }

  /* ── Dog wrap ── */
  .fw-dog-wrap {
    position: absolute;
    bottom: 9%;
    left: 5%;
    z-index: 5;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Calm aura rings around dog ── */
  .fw-calm-ring {
    position: absolute;
    border-radius: 50%;
    border: 1.5px solid rgba(77, 232, 196, 0.35);
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    animation: calm-pulse 3s ease-in-out infinite;
  }

  .fw-calm-ring--1 {
    width: 108px;
    height: 108px;
    background: radial-gradient(circle, rgba(77, 232, 196, 0.12) 0%, transparent 70%);
    animation-delay: 0s;
  }
  .fw-calm-ring--2 {
    width: 150px;
    height: 150px;
    background: transparent;
    border-color: rgba(77, 232, 196, 0.2);
    animation-delay: 0.5s;
  }
  .fw-calm-ring--3 {
    width: 196px;
    height: 196px;
    background: transparent;
    border-color: rgba(77, 232, 196, 0.1);
    border-width: 1px;
    animation-delay: 1s;
  }

  @keyframes calm-pulse {
    0%, 100% { opacity: 0.7; transform: translateX(-50%) scale(1); }
    50%       { opacity: 1;   transform: translateX(-50%) scale(1.04); }
  }

  /* ── Dog scene ── */
  .fw-dog {
    position: relative;
    z-index: 6;
    animation: dog-lounge 3.5s ease-in-out infinite;
  }

  @keyframes dog-lounge {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-5px); }
  }

  .fw-dog-body {
    position: relative;
    width: 100px;
    height: 70px;
  }

  .fw-dog-torso {
    position: absolute;
    bottom: 0;
    left: 10px;
    width: 65px;
    height: 40px;
    background: var(--fw-dog-tan);
    border-radius: 30px 25px 15px 15px;
  }

  .fw-dog-head {
    position: absolute;
    top: -10px;
    left: -10px;
    width: 50px;
    height: 45px;
    background: var(--fw-dog-tan);
    border-radius: 50% 50% 40% 40%;
    z-index: 2;
  }

  .fw-dog-ear {
    position: absolute;
    width: 18px;
    height: 25px;
    background: var(--fw-dog-dark);
    border-radius: 50% 50% 30% 30%;
    top: -10px;
  }

  .fw-dog-ear--l {
    left: 3px;
    transform: rotate(-14deg);
    animation: ear-droop 4.5s ease-in-out infinite;
  }

  .fw-dog-ear--r {
    right: 3px;
    transform: rotate(14deg);
    animation: ear-droop 4.5s ease-in-out infinite reverse;
  }

  @keyframes ear-droop {
    0%, 100% { transform: rotate(-14deg); }
    50%       { transform: rotate(-20deg); }
  }

  .fw-dog-face {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 36px;
    height: 28px;
  }

  /* Closed peaceful eyes (— style) */
  .fw-dog-eye {
    position: absolute;
    top: 5px;
    width: 10px;
    height: 3px;
    background: #0b1a2e;
    border-radius: 2px;
  }

  .fw-dog-eye--l { left: 2px; }
  .fw-dog-eye--r { right: 2px; }

  .fw-dog-nose {
    position: absolute;
    bottom: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 9px;
    height: 6px;
    background: #0b1a2e;
    border-radius: 50%;
  }

  /* Small upward-curve smile */
  .fw-dog-smile {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 7px;
    border-bottom: 2.5px solid #0b1a2e;
    border-left: 1.5px solid #0b1a2e;
    border-right: 1.5px solid #0b1a2e;
    border-radius: 0 0 10px 10px;
  }

