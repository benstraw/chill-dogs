---
import { ROUTES } from '@data/routes';
import type { HomepageVariant } from '@components/modules/HomepageHero.astro';
import type { HomepageArticleFeed } from '@utils/homepage-articles';

interface Props {
  variant?: HomepageVariant;
  articleFeed: HomepageArticleFeed;
}

const { variant, articleFeed } = Astro.props;
const isV6 = variant === 'v6';

const shopCards = [
  {
    title: 'Best Cooling Products for Dogs',
    description: 'Mats, vests, bandanas, and frozen enrichment for hot days.',
    href: ROUTES.coolingTop,
    label: 'Cooling',
    color: 'cool',
  },
  {
    title: 'Best Calming Products for Anxious Dogs',
    description: 'Wraps, chews, lick mats, and snuffle mats for restless dogs.',
    href: ROUTES.calmingTop,
    label: 'Calming',
    color: 'calm',
  },
  {
    title: 'Best Calming Dog Beds',
    description: 'Supportive beds for rest, recovery, and relaxation — curated for anxious dogs.',
    href: ROUTES.comfortCalmingBeds,
    label: 'Comfort',
    color: 'comfort',
  },
  {
    title: 'Dog GPS Trackers & Safety',
    description: 'Cellular, off-grid, and Bluetooth tracking — know which type fits your terrain.',
    href: ROUTES.trackingTop,
    label: 'Gear',
    color: 'gear',
  },
];

const topGuides = [
  { title: 'Best Cooling Products for Dogs', description: 'Mats, vests, bandanas, and frozen enrichment', href: ROUTES.coolingTop },
  { title: 'Best Calming Products for Anxious Dogs', description: 'Wraps, chews, lick mats, and snuffle mats', href: ROUTES.calmingTop },
  { title: 'Comfort & Rest for Dogs', description: 'Supportive beds, cozy blankets, and comforting toys for dogs of every age.', href: ROUTES.comfortHub },
  { title: 'Dog GPS Trackers & Safety', description: 'Cellular, off-grid, and Bluetooth tracking — know which type fits your terrain.', href: ROUTES.trackingTop },
];

const pinnedGuideRoutes = [
  {
    title: 'Travel Crates for Road Trips',
    description: 'Hard-sided and soft folding crates for dogs who travel by car.',
    href: ROUTES.comfortTravelCrates,
    color: 'comfort',
  },
];
---

{isV6 ? (
  <>
    {/* ── From the Guide ── */}
    <section class="guide-section container">
      <h2 class="section-title">From the Guide</h2>
      <div class="featured-grid">
        {articleFeed.featuredArticles.map((article) => (
          <a
            href={article.href}
            class="article-card"
            data-home-article="true"
            data-track="collector_to_converter_click"
            data-to-page={article.href}
            data-link-position="homepage-featured-articles"
          >
            <div class="article-img-wrap">
              <img
                src={typeof article.image === 'string' ? article.image : article.image.src}
                alt=""
                class="article-img"
                width="400"
                height="210"
                loading="lazy"
              />
            </div>
            <div class="article-body">
              <span class={`article-label article-label--${article.color}`}>{article.label}</span>
              <h3 class="article-title">{article.title}</h3>
              <p class="article-desc">{article.description}</p>
              <span class="article-read">Read →</span>
            </div>
          </a>
        ))}
      </div>

      <div class="more-grid">
        {[...articleFeed.moreArticles, ...pinnedGuideRoutes].map((article) => (
          <a
            href={article.href}
            class={`more-card more-card--${article.color}`}
            data-home-article={articleFeed.moreArticles.includes(article) ? 'true' : undefined}
            data-track="collector_to_converter_click"
            data-to-page={article.href}
            data-link-position="homepage-more-articles"
          >
            <h3 class="more-title">{article.title}</h3>
            <p class="more-desc">{article.description}</p>
          </a>
        ))}
      </div>
    </section>

    {/* ── Newsletter (injected from parent) ── */}
    <slot name="newsletter" />

    {/* ── Shop by Need ── */}
    <section class="shop container">
      <h2 class="section-title">Shop by Need</h2>
      <div class="shop-grid">
        {shopCards.map((card) => (
          <a
            href={card.href}
            class={`shop-card shop-card--${card.color}`}
            data-track="collector_to_converter_click"
            data-to-page={card.href}
            data-link-position="homepage-shop"
          >
            <span class={`shop-label shop-label--${card.color}`}>{card.label}</span>
            <h3 class="shop-title">{card.title}</h3>
            <p class="shop-desc">{card.description}</p>
            <span class="shop-cta">Explore picks →</span>
          </a>
        ))}
      </div>
    </section>
  </>
) : (
  <>
    <section class="featured container">
      <h2 class="section-title">Top Guides</h2>
      <div class="cards-grid">
        {topGuides.map((guide) => (
          <a href={guide.href} class="guide-card" data-track="collector_to_converter_click" data-to-page={guide.href} data-link-position="homepage-top-guides">
            <h3 class="guide-title">{guide.title}</h3>
            <p class="guide-description">{guide.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="latest container">
      <h2 class="section-title">Latest Guides</h2>
      <div class="cards-grid">
        {articleFeed.latestGuides.map((guide) => (
          <a href={guide.href} class="guide-card" data-track="collector_to_converter_click" data-to-page={guide.href} data-link-position="homepage-latest-guides">
            <h3 class="guide-title">{guide.title}</h3>
            <p class="guide-description">{guide.description}</p>
          </a>
        ))}
      </div>
    </section>
  </>
)}

<style>
  /* ── Shared ── */
  .section-title {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    font-weight: var(--weight-extrabold);
    text-align: center;
    margin-bottom: var(--space-xl);
    color: var(--color-charcoal);
    letter-spacing: -0.01em;
  }

  /* ══════════════════════════════════════
     v6 — Shop by Need
     ══════════════════════════════════════ */

  .shop {
    padding-block: var(--space-3xl);
  }

  .shop-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .shop-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-xl) var(--space-lg);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-charcoal);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .shop-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .shop-card--cool    { background: linear-gradient(150deg, hsl(195, 70%, 96%), hsl(202, 48%, 86%)); }
  .shop-card--calm    { background: linear-gradient(150deg, hsl(150, 35%, 96%), hsl(158, 36%, 85%)); }
  .shop-card--comfort { background: linear-gradient(150deg, hsl(345, 45%, 97%), hsl(340, 44%, 87%)); }
  .shop-card--gear    { background: linear-gradient(150deg, hsl(220, 15%, 95%), hsl(220, 12%, 88%)); }

  .shop-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .shop-label--cool    { color: hsl(200, 80%, 28%); }
  .shop-label--calm    { color: hsl(155, 50%, 26%); }
  .shop-label--comfort { color: hsl(345, 38%, 38%); }
  .shop-label--gear    { color: hsl(220, 20%, 35%); }

  .shop-title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-snug);
    color: var(--color-charcoal);
  }

  .shop-desc {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    opacity: 0.65;
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  .shop-cta {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-charcoal);
    opacity: 0.8;
    margin-top: var(--space-xs);
  }

  /* ══════════════════════════════════════
     v6 — From the Guide
     ══════════════════════════════════════ */

  .guide-section {
    padding-block: var(--space-3xl);
    border-top: 1px solid var(--color-border);
  }

  /* Featured 3-up with OG images */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .article-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-charcoal);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: white;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.07);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .article-img-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .article-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .article-card:hover .article-img {
    transform: scale(1.04);
  }

  .article-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md) var(--space-lg) var(--space-lg);
    flex: 1;
  }

  .article-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .article-label--cool    { color: hsl(200, 80%, 28%); }
  .article-label--calm    { color: hsl(155, 50%, 26%); }
  .article-label--comfort { color: hsl(345, 38%, 38%); }
  .article-label--gear    { color: hsl(220, 20%, 35%); }

  .article-title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    line-height: var(--leading-snug);
    color: var(--color-charcoal);
  }

  .article-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  .article-read {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-charcoal);
    opacity: 0.6;
    margin-top: var(--space-xs);
  }

  /* Compact more-articles grid */
  .more-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .more-card {
    display: block;
    padding: var(--space-md) var(--space-lg);
    border-left: 3px solid;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    background: var(--color-surface);
    text-decoration: none;
    color: var(--color-charcoal);
    transition: transform var(--transition-fast);
  }

  .more-card:hover {
    transform: translateX(3px);
  }

  .more-card--cool    { border-color: hsl(200, 60%, 60%); }
  .more-card--calm    { border-color: hsl(155, 42%, 57%); }
  .more-card--comfort { border-color: hsl(345, 42%, 65%); }
  .more-card--gear    { border-color: hsl(220, 20%, 55%); }

  .more-title {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    line-height: var(--leading-snug);
    color: var(--color-charcoal);
    margin-bottom: var(--space-xs);
  }

  .more-desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  /* ══════════════════════════════════════
     Default (non-v6) layout
     ══════════════════════════════════════ */

  .featured,
  .latest {
    padding-block: var(--space-3xl);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .featured .cards-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .guide-card {
    display: block;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: var(--space-lg);
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .guide-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    color: inherit;
  }

  .guide-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .guide-description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* ══════════════════════════════════════
     Responsive
     ══════════════════════════════════════ */

  @media (max-width: 1024px) {
    .shop-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }
    .more-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .shop-grid,
    .featured-grid,
    .more-grid,
    .cards-grid,
    .featured .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
