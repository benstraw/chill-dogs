---
import Disclosure from '@components/modules/Disclosure.astro';
import CalmingDisclaimer from '@components/modules/CalmingDisclaimer.astro';
import type { CollectorBodyConfig } from '@data/collector-bodies';

interface Props {
  config: CollectorBodyConfig;
}

const { config } = Astro.props;
const accentColor = config.accent === 'sage' ? 'var(--color-sage)' : config.accent === 'terracotta' ? 'var(--color-terracotta)' : 'var(--color-primary)';
---

{config.start && (
  <section class="start-here">
    <div class="start-here-inner" style={`--collector-accent: ${accentColor}`}>
      <span class="start-here-label">Start here</span>
      <h2>
        <a
          href={config.start.href}
          data-track="collector_to_converter_click"
          data-from-page={config.fromPage}
          data-to-page={config.start.dataToPage}
          data-link-position="hero"
        >
          {config.start.title}
        </a>
      </h2>
      <p>{config.start.description}</p>
    </div>
  </section>
)}

{config.sections.map((section) => (
  <section class="section-block">
    <h2 class="section-heading">{section.heading}</h2>
    {section.intro && <p class="section-intro">{section.intro}</p>}
    <div class="cards-grid">
      {section.cards.map((card) => (
        <a
          href={card.href}
          class="cat-card"
          data-track="collector_to_converter_click"
          data-from-page={config.fromPage}
          data-to-page={card.dataToPage}
          data-category={card.dataCategory}
          data-link-position="section"
          style={`--collector-accent: ${accentColor}`}
        >
          <h3>{card.title}</h3>
          <p>{card.description}</p>
          <span class="cat-card-link">{card.linkLabel}</span>
        </a>
      ))}
    </div>
  </section>
))}

{config.showCalmingDisclaimer && <CalmingDisclaimer />}

<Disclosure showSafety={config.disclosureShowSafety} />

<style>
  .start-here {
    max-width: var(--max-width-prose);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) 0;
  }

  .start-here-inner {
    background: var(--color-surface);
    border: 2px solid var(--collector-accent);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
  }

  .start-here-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--collector-accent);
    margin-bottom: var(--space-sm);
  }

  .start-here-inner h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
  }

  .start-here-inner h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .start-here-inner h2 a:hover {
    color: var(--collector-accent);
  }

  .start-here-inner p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .section-block {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) var(--space-xl);
  }

  .section-heading {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .section-intro {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .cat-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow var(--transition-base);
    display: flex;
    flex-direction: column;
  }

  .cat-card:hover {
    box-shadow: var(--shadow-md);
  }

  .cat-card h3 {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-sm);
  }

  .cat-card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    flex: 1;
    margin-bottom: var(--space-md);
  }

  .cat-card-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--collector-accent);
  }

  .cat-card:hover .cat-card-link {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }

  :global(.disc-inner a) {
    color: var(--collector-accent);
  }
</style>
