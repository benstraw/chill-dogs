---
import Disclosure from '@components/modules/Disclosure.astro';
---

<section class="start-here">
  <div class="start-here-inner">
    <span class="start-here-label">Start here</span>
    <h2>
      <a
        href="/calming/best-calming-products-for-anxious-dogs/"
        data-track="collector_to_converter_click"
        data-from-page="calming-hub"
        data-to-page="/calming/best-calming-products-for-anxious-dogs/"
        data-link-position="hero"
      >
        Best Calming Products for Anxious Dogs
      </a>
    </h2>
    <p>Our main guide covers ThunderShirt, calming chews, lick mats, and snuffle mats using the exact tools most dog owners actually consider first.</p>
  </div>
</section>

<section class="categories">
  <h2 class="categories-heading">Featured Guides</h2>
  <div class="categories-grid">
    <a
      href="/calming/best-calming-products-for-anxious-dogs/"
      class="cat-card"
      data-track="collector_to_converter_click"
      data-from-page="calming-hub"
      data-to-page="/calming/best-calming-products-for-anxious-dogs/"
      data-link-position="section"
    >
      <h3>Best Calming Products for Anxious Dogs</h3>
      <p>Quick picks and scenario-based guidance for storms, fireworks, separation, and grooming stress — covering all 8 products we've compared.</p>
      <span class="cat-card-link">Read the guide &rarr;</span>
    </a>
    <a
      href="/best-thundershirt-alternatives/"
      class="cat-card"
      data-track="collector_to_converter_click"
      data-from-page="calming-hub"
      data-to-page="/best-thundershirt-alternatives/"
      data-link-position="section"
    >
      <h3>Best ThunderShirt Alternatives for Dogs</h3>
      <p>Who should buy ThunderShirt, who should skip it, and which alternatives actually work better for different anxiety triggers.</p>
      <span class="cat-card-link">Compare options &rarr;</span>
    </a>
  </div>
</section>

<Disclosure showSafety={false} />

<style>
  .start-here {
    max-width: var(--max-width-prose);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) 0;
  }

  .start-here-inner {
    background: var(--color-surface);
    border: 2px solid var(--color-sage);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
  }

  .start-here-label {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-sage);
    margin-bottom: var(--space-sm);
  }

  .start-here-inner h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-sm);
  }

  .start-here-inner h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .start-here-inner h2 a:hover {
    color: var(--color-sage);
  }

  .start-here-inner p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .categories {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) var(--space-xl);
  }

  .categories-heading {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .cat-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow var(--transition-base);
    display: flex;
    flex-direction: column;
  }

  .cat-card:hover {
    box-shadow: var(--shadow-md);
  }

  .cat-card h3 {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-sm);
  }

  .cat-card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    flex: 1;
    margin-bottom: var(--space-md);
  }

  .cat-card-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-sage);
  }

  .cat-card:hover .cat-card-link {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Sage link color for the Disclosure component on calming pages */
  :global(.disc-inner a) {
    color: var(--color-sage);
  }
</style>
