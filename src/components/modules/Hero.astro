---
import AffiliateLink from '@components/AffiliateLink.astro';

interface HeroCta {
  label: string;
  href: string;
  isAffiliate?: boolean;
}

interface Props {
  title: string;
  subtitle?: string;
  disclaimer?: string;
  primaryCta: HeroCta;
  secondaryCta?: HeroCta;
  pageSlug?: string;
}

const { title, subtitle, disclaimer, primaryCta, secondaryCta, pageSlug = '' } = Astro.props;

function isAmazonUrl(href: string) {
  return href.includes('amazon.com') || href.includes('amzn.');
}

const primaryIsAffiliate = primaryCta.isAffiliate ?? isAmazonUrl(primaryCta.href);
const secondaryIsAffiliate = secondaryCta ? (secondaryCta.isAffiliate ?? isAmazonUrl(secondaryCta.href)) : false;
---

<section class="hero">
  <div class="hero-inner">
    <h1 class="hero-title">{title}</h1>
    {subtitle && <p class="hero-subtitle">{subtitle}</p>}
    {disclaimer && <p class="hero-disclaimer">{disclaimer}</p>}
    <div class="hero-ctas">
      {primaryIsAffiliate ? (
        <AffiliateLink
          href={primaryCta.href}
          class="hero-cta hero-cta--primary"
          data-track="amazon_outbound_click"
          data-page-slug={pageSlug}
          data-position="hero-primary"
          data-destination="amazon.com"
        >
          {primaryCta.label}
        </AffiliateLink>
      ) : (
        <a
          href={primaryCta.href}
          class="hero-cta hero-cta--primary"
          data-track="collector_to_converter_click"
          data-from-page={pageSlug}
          data-to-page={primaryCta.href}
          data-link-position="hero-primary"
        >
          {primaryCta.label}
        </a>
      )}
      {secondaryCta && (
        secondaryIsAffiliate ? (
          <AffiliateLink
            href={secondaryCta.href}
            class="hero-cta hero-cta--secondary"
            data-track="amazon_outbound_click"
            data-page-slug={pageSlug}
            data-position="hero-secondary"
            data-destination="amazon.com"
          >
            {secondaryCta.label}
          </AffiliateLink>
        ) : (
          <a
            href={secondaryCta.href}
            class="hero-cta hero-cta--secondary"
            data-track="collector_to_converter_click"
            data-from-page={pageSlug}
            data-to-page={secondaryCta.href}
            data-link-position="hero-secondary"
          >
            {secondaryCta.label}
          </a>
        )
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-bg-cool);
    padding: var(--space-3xl) var(--space-lg);
    text-align: center;
  }

  .hero-inner {
    max-width: var(--max-width-prose);
    margin: 0 auto;
  }

  .hero-title {
    font-size: var(--text-4xl);
    font-weight: var(--weight-extrabold);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-md);
    color: var(--color-text);
  }

  .hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-lg);
  }

  .hero-disclaimer {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: var(--space-lg);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-cta {
    display: inline-block;
    font-weight: var(--weight-semibold);
    padding: var(--space-sm) var(--space-xl);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .hero-cta--primary {
    background: var(--color-primary);
    color: var(--color-text-inverse);
  }

  .hero-cta--primary:hover {
    background: var(--color-primary-hover);
    color: var(--color-text-inverse);
  }

  .hero-cta--secondary {
    background: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .hero-cta--secondary:hover {
    background: var(--color-primary);
    color: var(--color-text-inverse);
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-2xl) var(--space-md);
    }

    .hero-title {
      font-size: var(--text-3xl);
    }

    .hero-ctas {
      flex-direction: column;
      align-items: center;
    }

    .hero-cta {
      width: 100%;
      max-width: 320px;
      text-align: center;
    }
  }
</style>
