---
import AffiliateLink from '@components/AffiliateLink.astro';
import type { CoolingProduct } from '@data/cooling-products';

interface Props {
  products: CoolingProduct[];
  pageSlug?: string;
}

const { products, pageSlug = '' } = Astro.props;
---

<div class="ct-wrapper">
  <table class="ct-table">
    <thead>
      <tr>
        <th scope="col">Product</th>
        <th scope="col">Best For</th>
        <th scope="col">Cooling Method</th>
        <th scope="col">Sizing</th>
        <th scope="col" class="ct-cta-col"></th>
      </tr>
    </thead>
    <tbody>
      {products.map((product, i) => (
        <tr>
          <td class="ct-product-cell">
            {product.image && (
              <img
                src={product.image.src}
                alt=""
                class="ct-thumb"
                loading="lazy"
                decoding="async"
                width="80"
                height="80"
              />
            )}
            <span class="ct-product-name">{product.name}</span>
          </td>
          <td>{product.bestFor}</td>
          <td>{product.coolingMethod || '—'}</td>
          <td>{product.sizingNote || '—'}</td>
          <td class="ct-cta-cell">
            <AffiliateLink
              href={product.amazonUrl}
              class="ct-cta"
              data-track="amazon_outbound_click"
              data-page-type="converter"
              data-page-slug={pageSlug}
              data-product-name={product.name}
              data-product-category={product.category}
              data-position={String(i + 1)}
              data-destination="amazon.com"
              data-table="true"
            >
              Check Price
            </AffiliateLink>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<!-- Mobile stacked cards (shown below 768px) -->
<div class="ct-mobile">
  {products.map((product, i) => (
    <div class="ct-mobile-card">
      {product.image && (
        <img
          src={product.image.src}
          alt=""
          class="ct-mobile-thumb"
          loading="lazy"
          decoding="async"
          width="120"
          height="120"
        />
      )}
      <h3 class="ct-mobile-name">{product.name}</h3>
      <dl class="ct-mobile-dl">
        <dt>Best For</dt>
        <dd>{product.bestFor}</dd>
        <dt>Cooling Method</dt>
        <dd>{product.coolingMethod || '—'}</dd>
        {product.sizingNote && (
          <>
            <dt>Sizing</dt>
            <dd>{product.sizingNote}</dd>
          </>
        )}
      </dl>
      <AffiliateLink
        href={product.amazonUrl}
        class="ct-cta"
        data-track="amazon_outbound_click"
        data-page-type="converter"
        data-page-slug={pageSlug}
        data-product-name={product.name}
        data-product-category={product.category}
        data-position={String(i + 1)}
        data-destination="amazon.com"
        data-table="true"
      >
        Check Price on Amazon
      </AffiliateLink>
    </div>
  ))}
</div>

<style>
  .ct-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: var(--space-2xl);
  }

  .ct-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .ct-table th {
    background: var(--color-bg-alt);
    font-weight: var(--weight-semibold);
    text-align: left;
    padding: var(--space-sm) var(--space-md);
    white-space: nowrap;
    border-bottom: 2px solid var(--color-border);
  }

  .ct-table td {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
    line-height: var(--leading-normal);
  }

  .ct-product-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    text-align: center;
    min-width: 140px;
  }

  .ct-thumb {
    display: block;
    width: 80px;
    height: 80px;
    object-fit: contain;
    border-radius: var(--radius-sm);
    background: #fff;
  }

  .ct-product-name {
    font-weight: var(--weight-semibold);
    white-space: normal;
    line-height: var(--leading-tight);
  }

  .ct-cta-col {
    width: 140px;
  }

  .ct-cta-cell {
    text-align: center;
  }

  :global(.ct-cta) {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-text-inverse) !important;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-md);
    text-decoration: none;
    white-space: nowrap;
    transition: background var(--transition-fast);
  }

  :global(.ct-cta:hover) {
    background: var(--color-primary-hover);
    color: var(--color-text-inverse) !important;
  }

  :global(.ct-cta:focus-visible) {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Desktop: show table, hide cards */
  .ct-mobile { display: none; }

  @media (max-width: 768px) {
    .ct-wrapper { display: none; }
    .ct-mobile { display: block; }
  }

  .ct-mobile-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .ct-mobile-thumb {
    display: block;
    width: 120px;
    height: 120px;
    object-fit: contain;
    border-radius: var(--radius-sm);
    background: #fff;
    margin: 0 auto var(--space-sm);
  }

  .ct-mobile-name {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    text-align: center;
    margin-bottom: var(--space-sm);
  }

  .ct-mobile-dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xs) var(--space-md);
    font-size: var(--text-sm);
    margin-bottom: var(--space-md);
  }

  .ct-mobile-dl dt {
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
  }

  .ct-mobile-dl dd {
    margin: 0;
    color: var(--color-text);
  }
</style>
