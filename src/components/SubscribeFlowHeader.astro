---
import { Image } from 'astro:assets';
import { ROUTES } from '@data/routes';
import pawLogo from '../../public/images/paw-logo.png';
---

<div class="subscribe-flow-header">
  <div class="container">
    <a href={ROUTES.home} class="brand-link" aria-label="Chill-Dogs home">
      <Image src={pawLogo} alt="" class="brand-icon" width={32} height={32} loading="eager" fetchpriority="high" />
      <span>Chill-Dogs</span>
    </a>
  </div>
</div>

<style>
  .subscribe-flow-header {
    padding-top: var(--space-lg);
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--weight-extrabold);
    color: var(--color-text);
    text-decoration: none;
  }

  .brand-link:hover {
    color: var(--color-primary);
  }

  .brand-icon {
    width: 2rem;
    height: 2rem;
    object-fit: contain;
  }
 </style>
