---
import AffiliateLink from './AffiliateLink.astro';
import type { Product } from '@utils/types';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const tagLabels: Record<string, string> = {
  'best-overall': 'Best Overall',
  'budget': 'Budget Pick',
  'premium': 'Premium Pick',
};
---

<div class="product-card">
  {product.tag && (
    <span class="product-tag">{tagLabels[product.tag] || product.tag}</span>
  )}
  {product.image && (
    <div class="product-image">
      <img src={product.image} alt={product.name} loading="lazy" />
    </div>
  )}
  <div class="product-body">
    <h3 class="product-name">{product.name}</h3>
    {product.priceNote && (
      <p class="product-price">{product.priceNote}</p>
    )}
    {product.description && (
      <p class="product-desc">{product.description}</p>
    )}
    <div class="product-lists">
      {product.pros && product.pros.length > 0 && (
        <div class="product-pros">
          <h4>Pros</h4>
          <ul>
            {product.pros.map((pro) => <li>{pro}</li>)}
          </ul>
        </div>
      )}
      {product.cons && product.cons.length > 0 && (
        <div class="product-cons">
          <h4>Cons</h4>
          <ul>
            {product.cons.map((con) => <li>{con}</li>)}
          </ul>
        </div>
      )}
    </div>
    {product.affiliateUrl && (
      <AffiliateLink href={product.affiliateUrl} class="product-cta">
        Check Price on Amazon
      </AffiliateLink>
    )}
  </div>
</div>

<style>
  .product-card {
    position: relative;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    transition: box-shadow var(--transition-base);
  }

  .product-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .product-tag {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    background: var(--color-primary);
    color: var(--color-text-inverse);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-full);
    z-index: 1;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .product-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-body {
    padding: var(--space-lg);
  }

  .product-name {
    font-size: var(--text-lg);
    margin-bottom: var(--space-xs);
  }

  .product-price {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-sm);
  }

  .product-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .product-lists {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .product-lists h4 {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .product-pros h4 {
    color: var(--color-accent);
  }

  .product-cons h4 {
    color: var(--color-primary);
  }

  .product-lists ul {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .product-lists li {
    padding-left: var(--space-md);
    position: relative;
    margin-bottom: var(--space-xs);
  }

  .product-pros li::before {
    content: '+';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: var(--weight-bold);
  }

  .product-cons li::before {
    content: '\2013';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: var(--weight-bold);
  }

  :global(.product-cta) {
    display: block;
    text-align: center;
    background: var(--color-primary);
    color: var(--color-text-inverse) !important;
    font-weight: var(--weight-semibold);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
    text-decoration: none;
  }

  :global(.product-cta:hover) {
    background: var(--color-primary-hover);
    color: var(--color-text-inverse) !important;
  }
</style>
