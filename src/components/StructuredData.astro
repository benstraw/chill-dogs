---
interface Props {
  type: 'article' | 'product' | 'website';
  title: string;
  description: string;
  date?: Date;
  image?: string;
}

const { type, title, description, date, image } = Astro.props;

const siteUrl = Astro.site?.href || 'https://chill-dogs.com';
const pageUrl = Astro.url.href;

function buildSchema() {
  if (type === 'article') {
    return {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      url: pageUrl,
      datePublished: date?.toISOString(),
      dateModified: date?.toISOString(),
      image: image ? new URL(image, siteUrl).href : undefined,
      publisher: {
        '@type': 'Organization',
        name: 'Chill Dogs',
        url: siteUrl,
      },
    };
  }

  return {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Chill Dogs',
    description,
    url: siteUrl,
  };
}

const schema = buildSchema();
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
