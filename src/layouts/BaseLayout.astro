---
import '@fontsource-variable/nunito';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@styles/tokens.css';
import '@styles/reset.css';
import '@styles/utilities.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Analytics from '@components/Analytics.astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  navAccent?: string;
  hideChrome?: boolean;
}

const {
  title,
  description = 'Curated gear, gift guides, and party ideas for dogs who live the good life.',
  ogImage = '/og-default.jpg',
  canonicalUrl,
  noindex = false,
  navAccent,
  hideChrome = false,
} = Astro.props;

const siteTitle = title === 'Home'
  ? 'Chill-Dogs — Cooling & Calming Products for Dogs'
  : `${title} | Chill-Dogs`;
const resolvedOgImage = new URL(ogImage, Astro.site).href;
const resolvedCanonical = canonicalUrl || Astro.url.href;
const isStaging = import.meta.env.VERCEL_ENV === 'preview' || import.meta.env.VERCEL_ENV === 'development';
---

<!doctype html>
<html lang="en" style={navAccent ? `--color-nav-accent: ${navAccent}` : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    {(noindex || isStaging) && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:site_name" content="Chill-Dogs" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <slot name="head" />
    <Analytics />
  </head>
  <body>
    <a href="#main-content" class="sr-only">Skip to content</a>
    {!hideChrome && <Header />}
    <main id="main-content">
      <slot />
    </main>
    {!hideChrome && <Footer />}
    <SpeedInsights />
  </body>
</html>
