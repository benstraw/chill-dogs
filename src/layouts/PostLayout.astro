---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  heroImage?: string;
  ogImage?: string;
  category: string;
}

const { title, description, date, heroImage, ogImage, category } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabels: Record<string, string> = {
  'gift-guides': 'Gift Guides',
  'luxury-gear': 'Luxury & Gear',
  blog: 'Blog',
};
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <article class="post">
    <header class="post-header">
      <div class="container">
        <span class="post-category">{categoryLabels[category] || category}</span>
        <h1>{title}</h1>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    </header>
    {heroImage && (
      <div class="post-hero container">
        <img src={heroImage} alt="" loading="eager" />
      </div>
    )}
    <div class="container prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-xl);
    text-align: center;
  }

  .post-category {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-sm);
  }

  .post-header h1 {
    font-size: var(--text-4xl);
    max-width: var(--max-width-prose);
    margin-inline: auto;
  }

  .post-header time {
    display: block;
    margin-top: var(--space-md);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .post-hero {
    margin-bottom: var(--space-2xl);
  }

  .post-hero img {
    width: 100%;
    max-width: var(--max-width-prose);
    margin-inline: auto;
    border-radius: var(--radius-lg);
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .post .prose {
    padding-bottom: var(--space-4xl);
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: var(--text-3xl);
    }
  }
</style>
