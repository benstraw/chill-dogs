---
import BaseLayout from './BaseLayout.astro';
import AffiliateDisclosure from '@components/AffiliateDisclosure.astro';
import TopPicks from '@components/TopPicks.astro';
import ProductGrid from '@components/ProductGrid.astro';
import type { Product } from '@utils/types';

interface Props {
  title: string;
  description: string;
  date: Date;
  heroImage?: string;
  ogImage?: string;
  category: string;
  products: Product[];
}

const { title, description, date, heroImage, ogImage, category, products } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabels: Record<string, string> = {
  'gift-guides': 'Gift Guides',
  blog: 'Blog',
};
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <article class="converter">
    <header class="converter-header">
      <div class="container">
        <span class="converter-category">{categoryLabels[category] || category}</span>
        <h1>{title}</h1>
        <p class="converter-desc">{description}</p>
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <AffiliateDisclosure variant="banner" />
      </div>
    </header>

    {products.length > 0 && (
      <section class="container top-picks-section">
        <TopPicks products={products} />
      </section>
    )}

    <div class="container prose">
      <slot />
    </div>

    {products.length > 0 && (
      <section class="container product-grid-section">
        <h2 class="section-title">All Products Compared</h2>
        <ProductGrid products={products} />
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .converter-header {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-xl);
    text-align: center;
    background: linear-gradient(to bottom, var(--color-bg-alt), var(--color-bg));
  }

  .converter-category {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-sm);
  }

  .converter-header h1 {
    font-size: var(--text-4xl);
    max-width: 800px;
    margin-inline: auto;
  }

  .converter-desc {
    max-width: 600px;
    margin-inline: auto;
    margin-top: var(--space-md);
    color: var(--color-text-muted);
    font-size: var(--text-lg);
  }

  .converter-header time {
    display: block;
    margin-top: var(--space-sm);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .top-picks-section {
    padding-block: var(--space-2xl);
  }

  .product-grid-section {
    padding-block: var(--space-3xl);
  }

  .section-title {
    font-size: var(--text-2xl);
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .converter .prose {
    padding-block: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .converter-header h1 {
      font-size: var(--text-3xl);
    }
  }
</style>
