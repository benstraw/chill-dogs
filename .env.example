# PostHog (primary analytics + experiments platform)
# Project API key from posthog.com → Project Settings → Project API Key
PUBLIC_POSTHOG_KEY=
# PostHog ingest host — US cloud default; use https://eu.i.posthog.com for EU cloud or your self-hosted URL
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Site URL (used for OG images and canonical URLs)
PUBLIC_SITE_URL=https://chill-dogs.com

# Maintenance mode — set to "true" to show coming-soon page at / (all other routes remain accessible)
MAINTENANCE_MODE=

# Amazon product data APIs (for scripts/fetch-amazon-data.ts)
# SerpAPI — preferred, 250 free searches/month (serpapi.com)
SERP_API_KEY=
# SearchAPI — backup, 100 free searches/month (searchapi.io)
SEARCHAPI_KEY=
